@model List<COROLA_RENTACAR.EntityLayer.Entities.Brand>

@{
    ViewData["Title"] = "Brand List";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    var totalCount = Model?.Count ?? 0;
    var activeCount = Model?.Count(x => x.Status) ?? 0;
    var passiveCount = Model?.Count(x => !x.Status) ?? 0;
}

<style>
    :root {
        --bg-dark: #0d0f14;
        --bg-dark2: #13161e;
        --bg-dark3: #1a1e2a;
        --accent: #e8ff47;
        --accent-dim: rgba(232,255,71,.12);
        --accent2: #4f8dff;
        --accent2-dim: rgba(79,141,255,.12);
        --danger: #ff5259;
        --success: #30e0a1;
        --border: rgba(255,255,255,.07);
        --text: #e2e8f0;
        --text-muted: #7a8499;
        --radius: 12px;
        --radius-lg: 18px;
    }

    .bl-root {
        padding: 28px;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
        color: var(--text);
    }

    .bl-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
    }

    .bl-breadcrumb span {
        color: var(--text);
    }

    .bl-page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .bl-page-title {
        font-family: 'Syne', Georgia, sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
        margin: 0;
    }

    .bl-page-subtitle {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 6px;
    }

    .btn-accent {
        background: var(--accent);
        color: #0d0f14;
        border: none;
        border-radius: 10px;
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
    }

    .btn-accent:hover {
        color: #0d0f14;
        opacity: .85;
    }

    .btn-edit {
        background: var(--accent2-dim);
        color: var(--accent2);
        border: 1px solid rgba(79,141,255,.25);
        border-radius: 8px;
        padding: 6px 13px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
    }

    .btn-danger {
        background: rgba(255,82,89,.1);
        color: var(--danger);
        border: 1px solid rgba(255,82,89,.2);
        border-radius: 8px;
        padding: 6px 13px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
    }

    .bl-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 22px;
    }

    .bl-stat-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .bl-stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        font-size: 18px;
    }

    .bl-stat-icon.yellow {
        background: var(--accent-dim);
        color: var(--accent);
    }

    .bl-stat-icon.green {
        background: rgba(48,224,161,.1);
        color: var(--success);
    }

    .bl-stat-icon.red {
        background: rgba(255,82,89,.1);
        color: var(--danger);
    }

    .bl-stat-num {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 700;
        line-height: 1;
    }

    .bl-stat-label {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 3px;
    }

    .bl-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .bl-search-wrap {
        position: relative;
        flex: 1;
        min-width: 220px;
        max-width: 360px;
    }

    .bl-search-wrap input {
        width: 100%;
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        padding: 10px 13px 10px 36px;
        font-size: 13px;
        outline: none;
    }

    .bl-search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 14px;
        color: var(--text-muted);
    }

    .bl-filter-tabs {
        display: flex;
        gap: 6px;
    }

    .bl-filter-tab {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        cursor: pointer;
    }

    .bl-filter-tab.active {
        background: var(--accent-dim);
        border-color: rgba(232,255,71,.3);
        color: var(--accent);
    }

    .bl-view-toggle {
        display: flex;
        gap: 4px;
        margin-left: auto;
    }

    .bl-view-btn {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--bg-dark2);
        color: var(--text-muted);
        cursor: pointer;
        display: grid;
        place-items: center;
    }

    .bl-view-btn.active {
        background: var(--accent-dim);
        border-color: rgba(232,255,71,.3);
        color: var(--accent);
    }

    .bl-result-info {
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 14px;
    }

    .bl-result-info strong {
        color: var(--text);
    }

    .bl-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 16px;
    }

    .bl-grid.list-view {
        grid-template-columns: 1fr;
    }

    .bl-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .bl-card-top {
        position: relative;
        height: 110px;
        background: var(--bg-dark3);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bl-brand-logo {
        width: 72px;
        height: 72px;
        object-fit: contain;
        border-radius: 10px;
    }

    .bl-logo-placeholder {
        width: 72px;
        height: 72px;
        border-radius: 12px;
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        display: grid;
        place-items: center;
        font-size: 28px;
        font-weight: 700;
        color: var(--text-muted);
    }

    .bl-brand-id {
        position: absolute;
        top: 10px;
        left: 10px;
        font-size: 11px;
        color: var(--text-muted);
        background: rgba(0,0,0,.4);
        border-radius: 5px;
        padding: 2px 7px;
    }

    .bl-status-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 6px;
    }

    .bl-status-badge.active {
        background: rgba(48,224,161,.12);
        color: var(--success);
        border: 1px solid rgba(48,224,161,.25);
    }

    .bl-status-badge.passive {
        background: rgba(255,82,89,.1);
        color: var(--danger);
        border: 1px solid rgba(255,82,89,.2);
    }

    .bl-status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
    }

    .bl-card-body {
        padding: 14px 16px;
    }

    .bl-brand-name {
        font-family: 'Syne', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .bl-brand-meta {
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 14px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .bl-card-actions {
        display: flex;
        gap: 8px;
    }

    .bl-grid.list-view .bl-card {
        display: flex;
    }

    .bl-grid.list-view .bl-card-top {
        width: 110px;
        height: auto;
        min-height: 85px;
    }

    .bl-grid.list-view .bl-card-body {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .bl-grid.list-view .bl-brand-meta {
        margin-bottom: 0;
    }

    .bl-grid.list-view .bl-card-actions {
        margin-left: auto;
    }

    .bl-empty {
        grid-column: 1 / -1;
        padding: 60px 20px;
        color: var(--text-muted);
        text-align: center;
    }

    .bl-modal-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.7);
        z-index: 200;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
    }

    .bl-modal-backdrop.open {
        display: flex;
    }

    .bl-modal {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px 28px 28px;
        width: 100%;
        max-width: 380px;
        text-align: center;
        position: relative;
    }

    .bl-modal-close {
        position: absolute;
        top: 14px;
        right: 16px;
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 18px;
        cursor: pointer;
    }

    .bl-modal-icon {
        font-size: 38px;
        margin-bottom: 10px;
    }

    .bl-modal-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .bl-modal-msg {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.65;
        margin-bottom: 24px;
    }

    .bl-modal-actions {
        display: flex;
        gap: 10px;
        justify-content: center;
    }
</style>

<div class="bl-root">

    <div class="bl-breadcrumb">
        Vehicle Management <span>›</span> <span>Brand List</span>
    </div>

    <div class="bl-page-header">
        <div>
            <h1 class="bl-page-title">Brand Management</h1>
            <p class="bl-page-subtitle">View and manage all vehicle brands in the system.</p>
        </div>

        <a href="/Admin/Brand/CreateBrand" class="btn-accent">
            ＋ Add New Brand
        </a>
    </div>

    <div class="bl-stats">
        <div class="bl-stat-card">
            <div class="bl-stat-icon yellow">🏷️</div>
            <div>
                <div class="bl-stat-num">@totalCount</div>
                <div class="bl-stat-label">Total Brands</div>
            </div>
        </div>

        <div class="bl-stat-card">
            <div class="bl-stat-icon green">✅</div>
            <div>
                <div class="bl-stat-num">@activeCount</div>
                <div class="bl-stat-label">Active Brands</div>
            </div>
        </div>

        <div class="bl-stat-card">
            <div class="bl-stat-icon red">⛔</div>
            <div>
                <div class="bl-stat-num">@passiveCount</div>
                <div class="bl-stat-label">Inactive Brands</div>
            </div>
        </div>
    </div>

    <div class="bl-toolbar">
        <div class="bl-search-wrap">
            <span class="bl-search-icon">🔍</span>
            <input type="text" id="blSearch" placeholder="Search brand..." oninput="blRender()" />
        </div>

        <div class="bl-filter-tabs">
            <button type="button" class="bl-filter-tab active" onclick="blSetFilter('all', this)">All</button>
            <button type="button" class="bl-filter-tab" onclick="blSetFilter('active', this)">Active</button>
            <button type="button" class="bl-filter-tab" onclick="blSetFilter('passive', this)">Inactive</button>
        </div>

        <div class="bl-view-toggle">
            <button type="button" class="bl-view-btn active" id="blGridBtn" onclick="blSetView('grid')" title="Card View">⊞</button>
            <button type="button" class="bl-view-btn" id="blListBtn" onclick="blSetView('list')" title="List View">☰</button>
        </div>
    </div>

    <div class="bl-result-info" id="blResultInfo"></div>

    <div class="bl-grid" id="blGrid"></div>

</div>

<div class="bl-modal-backdrop" id="blConfirmModal">
    <div class="bl-modal">
        <button class="bl-modal-close" type="button" onclick="blCloseModal()">✕</button>

        <div class="bl-modal-icon">🗑️</div>
        <div class="bl-modal-title">Delete Brand</div>
        <p class="bl-modal-msg" id="blConfirmMsg"></p>

        <div class="bl-modal-actions">
            <button type="button"
                    class="btn-accent"
                    onclick="blCloseModal()"
                    style="background:var(--bg-dark3);color:var(--text);border:1px solid var(--border);">
                Cancel
            </button>

            <form id="blDeleteForm" method="post" action="">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger">🗑️ Yes, Delete</button>
            </form>
        </div>
    </div>
</div>

<script>
    const BL_DATA = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(b => new {
        b.BrandId,
        b.BrandName,
        b.LogoUrl,
        b.Status
    })));

    let blFilter = 'all';
    let blView = 'grid';

    function blGetFiltered() {
        const searchInput = document.getElementById('blSearch');
        const q = searchInput ? searchInput.value.toLowerCase() : '';

        return BL_DATA.filter(brand => {
            const brandName = (brand.BrandName || '').toLowerCase();

            const matchFilter =
                blFilter === 'all' ||
                (blFilter === 'active' && brand.Status) ||
                (blFilter === 'passive' && !brand.Status);

            return matchFilter && brandName.includes(q);
        });
    }

    function blSetFilter(filter, element) {
        blFilter = filter;

        document.querySelectorAll('.bl-filter-tab').forEach(tab => {
            tab.classList.remove('active');
        });

        element.classList.add('active');
        blRender();
    }

    function blSetView(viewType) {
        blView = viewType;

        document.getElementById('blGridBtn').classList.toggle('active', viewType === 'grid');
        document.getElementById('blListBtn').classList.toggle('active', viewType === 'list');

        blRender();
    }

    function blRender() {
        const items = blGetFiltered();
        const grid = document.getElementById('blGrid');

        grid.className = 'bl-grid' + (blView === 'list' ? ' list-view' : '');

        document.getElementById('blResultInfo').innerHTML =
            `<strong>${items.length}</strong> brands listed`;

        if (items.length === 0) {
            grid.innerHTML = `
                <div class="bl-empty">
                    <div style="font-size:42px;opacity:.45;">🔍</div>
                    <p>No brands found matching your search.</p>
                </div>`;
            return;
        }

        grid.innerHTML = items.map((brand, index) => blCardHtml(brand, index)).join('');
    }

    function blCardHtml(brand, index) {
        const brandName = brand.BrandName || '';
        const logoUrl = brand.LogoUrl || '';

        const logoHtml = logoUrl
            ? `<img class="bl-brand-logo"
                    src="${blEsc(logoUrl)}"
                    alt="${blEsc(brandName)}"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" />
               <div class="bl-logo-placeholder" style="display:none">${blEsc(brandName.charAt(0))}</div>`
            : `<div class="bl-logo-placeholder">${blEsc(brandName.charAt(0))}</div>`;

        const badge = brand.Status
            ? `<span class="bl-status-badge active"><span class="bl-status-dot"></span>Active</span>`
            : `<span class="bl-status-badge passive"><span class="bl-status-dot"></span>Inactive</span>`;

        const metaText = logoUrl ? 'Logo available' : 'No logo URL provided';

        const actions = `
            <div class="bl-card-actions">
                <a href="/Admin/Brand/UpdateBrand?id=${brand.BrandId}" class="btn-edit">✏️ Edit</a>
                <button type="button" class="btn-danger" onclick='blConfirmDelete(${brand.BrandId}, ${JSON.stringify(brandName)})'>
                    🗑️ Delete
                </button>
            </div>`;

        if (blView === 'list') {
            return `
                <div class="bl-card">
                    <div class="bl-card-top">
                        <span class="bl-brand-id">#${brand.BrandId}</span>
                        ${logoHtml}
                    </div>

                    <div class="bl-card-body">
                        <div style="flex:1;min-width:0;">
                            <div class="bl-brand-name">${blEsc(brandName)}</div>
                            <div class="bl-brand-meta">${blEsc(logoUrl || 'No logo URL provided')}</div>
                        </div>

                        ${badge}
                        ${actions}
                    </div>
                </div>`;
        }

        return `
            <div class="bl-card">
                <div class="bl-card-top">
                    <span class="bl-brand-id">#${brand.BrandId}</span>
                    ${badge}
                    ${logoHtml}
                </div>

                <div class="bl-card-body">
                    <div class="bl-brand-name">${blEsc(brandName)}</div>
                    <div class="bl-brand-meta">${metaText}</div>
                    ${actions}
                </div>
            </div>`;
    }

    function blConfirmDelete(id, name) {
        document.getElementById('blConfirmMsg').innerHTML =
            `<strong>${blEsc(name)}</strong> Are you sure you want to delete this brand?<br>This action cannot be undone.`;

        document.getElementById('blDeleteForm').action = `/Admin/Brand/DeleteBrand?id=${id}`;
        document.getElementById('blConfirmModal').classList.add('open');
    }

    function blCloseModal() {
        document.getElementById('blConfirmModal').classList.remove('open');
    }

    document.getElementById('blConfirmModal').addEventListener('click', function (event) {
        if (event.target === this) {
            blCloseModal();
        }
    });

    function blEsc(value) {
        if (!value) return '';

        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#x27;');
    }

    blRender();
</script>