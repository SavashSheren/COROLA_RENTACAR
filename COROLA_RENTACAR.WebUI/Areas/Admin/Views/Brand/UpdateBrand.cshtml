@model COROLA_RENTACAR.EntityLayer.Entities.Brand

@{
    ViewData["Title"] = "Update Brand";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --bg-dark: #0d0f14;
        --bg-dark2: #13161e;
        --bg-dark3: #1a1e2a;
        --accent: #e8ff47;
        --accent-dim: rgba(232,255,71,.12);
        --danger: #ff5259;
        --success: #30e0a1;
        --border: rgba(255,255,255,.07);
        --text: #e2e8f0;
        --text-muted: #7a8499;
        --radius: 14px;
    }

    .ub-root {
        padding: 28px;
        color: var(--text);
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    .ub-breadcrumb {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 8px;
    }

        .ub-breadcrumb a {
            color: var(--text-muted);
            text-decoration: none;
        }

            .ub-breadcrumb a:hover {
                color: var(--accent);
            }

    .ub-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .ub-page-title {
        font-size: 26px;
        font-weight: 800;
        margin: 0;
        color: var(--text);
    }

    .ub-page-subtitle {
        color: var(--text-muted);
        font-size: 13px;
        margin-top: 6px;
    }

    .ub-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 18px;
    }

    .ub-card,
    .ub-sidebar-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin-bottom: 16px;
        overflow: hidden;
    }

    .ub-card-head,
    .ub-sidebar-head {
        padding: 16px 18px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 800;
    }

    .ub-card-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: grid;
        place-items: center;
    }

        .ub-card-icon.yellow {
            background: var(--accent-dim);
            color: var(--accent);
        }

        .ub-card-icon.green {
            background: rgba(48,224,161,.12);
            color: var(--success);
        }

    .ub-card-title {
        font-size: 15px;
        font-weight: 800;
    }

    .ub-card-subtitle {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 3px;
    }

    .ub-card-body,
    .ub-sidebar-body {
        padding: 18px;
    }

    .ub-field {
        margin-bottom: 16px;
    }

        .ub-field label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 7px;
        }

    .ub-required {
        color: var(--danger);
    }

    .ub-field input {
        width: 100%;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        padding: 11px 13px;
        outline: none;
    }

        .ub-field input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-dim);
        }

    .ub-hint {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 6px;
    }

    .ub-validation-summary {
        background: rgba(255,82,89,.1);
        border: 1px solid rgba(255,82,89,.25);
        color: var(--danger);
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        font-size: 13px;
    }

    .ub-img-preview {
        height: 145px;
        border-radius: 12px;
        background: var(--bg-dark3);
        border: 1px dashed var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        color: var(--text-muted);
        text-align: center;
    }

        .ub-img-preview img {
            max-width: 120px;
            max-height: 100px;
            object-fit: contain;
            display: none;
        }

    .ub-toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .ub-toggle-label {
        font-weight: 800;
    }

    .ub-toggle-desc {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    .ub-toggle {
        width: 54px;
        height: 30px;
        border-radius: 999px;
        background: rgba(255,82,89,.25);
        padding: 4px;
        cursor: pointer;
        transition: .2s;
    }

        .ub-toggle.on {
            background: rgba(48,224,161,.35);
        }

    .ub-toggle-knob {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #fff;
        transition: .2s;
    }

    .ub-toggle.on .ub-toggle-knob {
        transform: translateX(24px);
    }

    .btn-accent,
    .btn-outline {
        border-radius: 10px;
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
    }

    .btn-accent {
        background: var(--accent);
        color: #0d0f14;
        border: none;
    }

    .btn-outline {
        background: var(--bg-dark3);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .ub-action-bar {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .ub-live-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        border-bottom: 1px solid var(--border);
        padding: 10px 0;
        font-size: 13px;
    }

    .ub-live-key {
        color: var(--text-muted);
    }

    .ub-live-val {
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        text-align: right;
    }

    .ub-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        border-radius: 8px;
        padding: 4px 9px;
        font-size: 12px;
        font-weight: 800;
    }

        .ub-status-pill.active {
            background: rgba(48,224,161,.12);
            color: var(--success);
        }

        .ub-status-pill.passive {
            background: rgba(255,82,89,.12);
            color: var(--danger);
        }

    @@media(max-width: 900px) {
        .ub-layout {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="ub-root">

    <div class="ub-breadcrumb">
        Vehicle Management <span>›</span>
        <a href="/Admin/Brand/BrandList">Brand List</a>
        <span>›</span>
        <span>Update Brand</span>
    </div>

    <div class="ub-page-header">
        <div>
            <h1 class="ub-page-title">Update Brand</h1>
            <p class="ub-page-subtitle">Edit the selected vehicle brand.</p>
        </div>

        <div style="display:flex;gap:10px;">
            <a href="/Admin/Brand/BrandList" class="btn-outline">✕ Cancel</a>
            <button type="button" class="btn-accent" onclick="ubSubmit()">💾 Save Changes</button>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="ub-validation-summary">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form id="ubForm" action="/Admin/Brand/UpdateBrand" method="post" novalidate>
        @Html.AntiForgeryToken()

        <input type="hidden" name="BrandId" value="@Model.BrandId" />

        <div class="ub-layout">

            <div>
                <div class="ub-card">
                    <div class="ub-card-head">
                        <div class="ub-card-icon yellow">🏷️</div>
                        <div>
                            <div class="ub-card-title">Brand Information</div>
                            <div class="ub-card-subtitle">Update brand name and logo URL</div>
                        </div>
                    </div>

                    <div class="ub-card-body">

                        <div class="ub-field">
                            <label>Brand Name <span class="ub-required">*</span></label>
                            <input type="text"
                                   id="ubBrandName"
                                   name="BrandName"
                                   value="@Model.BrandName"
                                   placeholder="e.g. Toyota, BMW, Audi"
                                   maxlength="50"
                                   oninput="ubSync()"
                                   autocomplete="off" />
                        </div>

                        <div class="ub-field">
                            <label>Logo URL</label>
                            <input type="text"
                                   id="ubLogoUrl"
                                   name="LogoUrl"
                                   value="@Model.LogoUrl"
                                   placeholder="https://example.com/logo.png"
                                   oninput="ubSync(); ubPreviewLogo(this.value)"
                                   autocomplete="off" />
                            <div class="ub-hint">Supported formats: PNG, SVG, WebP, JPG</div>
                        </div>

                        <div class="ub-img-preview">
                            <img id="ubPreviewTag" src="" alt="Logo Preview" />
                            <div id="ubPreviewPlaceholder">
                                <div style="font-size:32px;">🖼️</div>
                                <div>Logo preview</div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="ub-card">
                    <div class="ub-card-head">
                        <div class="ub-card-icon green">⚡</div>
                        <div>
                            <div class="ub-card-title">Status</div>
                            <div class="ub-card-subtitle">Brand visibility in the system</div>
                        </div>
                    </div>

                    <div class="ub-card-body">
                        <div class="ub-toggle-row">
                            <div>
                                <div class="ub-toggle-label" id="ubToggleLabel">@(Model.Status ? "Active" : "Inactive")</div>
                                <div class="ub-toggle-desc">Brand is visible and selectable in the system</div>
                            </div>

                            <div class="ub-toggle @(Model.Status ? "on" : "")" id="ubToggle" onclick="ubToggleStatus()">
                                <div class="ub-toggle-knob"></div>
                            </div>
                        </div>

                        <input type="hidden" id="ubStatusInput" name="Status" value="@(Model.Status.ToString().ToLower())" />
                    </div>
                </div>

                <div class="ub-action-bar">
                    <a href="/Admin/Brand/BrandList" class="btn-outline">✕ Cancel</a>
                    <button type="button" class="btn-accent" onclick="ubSubmit()">💾 Save Changes</button>
                </div>
            </div>

            <div>
                <div class="ub-sidebar-card">
                    <div class="ub-sidebar-head">📋 Live Preview</div>

                    <div class="ub-sidebar-body">
                        <div style="height:100px;background:var(--bg-dark3);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;overflow:hidden;">
                            <img id="ubSidePreview"
                                 src=""
                                 alt=""
                                 style="height:64px;object-fit:contain;display:none;" />

                            <div id="ubSidePlaceholder"
                                 style="width:64px;height:64px;border-radius:12px;background:var(--bg-dark2);display:grid;place-items:center;font-size:26px;font-weight:700;color:var(--text-muted);">
                                ?
                            </div>
                        </div>

                        <div class="ub-live-row">
                            <span class="ub-live-key">BrandId</span>
                            <span class="ub-live-val">@Model.BrandId</span>
                        </div>

                        <div class="ub-live-row">
                            <span class="ub-live-key">Brand Name</span>
                            <span class="ub-live-val" id="sumName">—</span>
                        </div>

                        <div class="ub-live-row">
                            <span class="ub-live-key">Logo URL</span>
                            <span class="ub-live-val" id="sumLogo">—</span>
                        </div>

                        <div class="ub-live-row" style="border-bottom:none;">
                            <span class="ub-live-key">Status</span>
                            <span id="sumStatus"></span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<script>
    let ubStatus = '@Model.Status'.toLowerCase() === 'true';

    function ubSubmit() {
        const name = document.getElementById('ubBrandName').value.trim();

        if (!name) {
            alert("Brand name is required.");
            return;
        }

        document.getElementById('ubForm').submit();
    }

    function ubToggleStatus() {
        ubStatus = !ubStatus;

        document.getElementById('ubStatusInput').value = ubStatus ? 'true' : 'false';
        document.getElementById('ubToggle').classList.toggle('on', ubStatus);
        document.getElementById('ubToggleLabel').innerText = ubStatus ? 'Active' : 'Inactive';

        ubSync();
    }

    function ubPreviewLogo(value) {
        const preview = document.getElementById('ubPreviewTag');
        const placeholder = document.getElementById('ubPreviewPlaceholder');
        const sidePreview = document.getElementById('ubSidePreview');
        const sidePlaceholder = document.getElementById('ubSidePlaceholder');

        if (!value) {
            preview.style.display = 'none';
            placeholder.style.display = 'block';

            sidePreview.style.display = 'none';
            sidePlaceholder.style.display = 'grid';
            return;
        }

        preview.src = value;
        preview.style.display = 'block';
        placeholder.style.display = 'none';

        sidePreview.src = value;
        sidePreview.style.display = 'block';
        sidePlaceholder.style.display = 'none';
    }

    function ubSync() {
        const name = document.getElementById('ubBrandName').value.trim();
        const logo = document.getElementById('ubLogoUrl').value.trim();

        document.getElementById('sumName').innerText = name || '—';
        document.getElementById('sumLogo').innerText = logo || '—';

        document.getElementById('sumStatus').innerHTML = ubStatus
            ? '<span class="ub-status-pill active">Active</span>'
            : '<span class="ub-status-pill passive">Inactive</span>';

        const sidePlaceholder = document.getElementById('ubSidePlaceholder');
        if (sidePlaceholder && !logo) {
            sidePlaceholder.innerText = name ? name.charAt(0).toUpperCase() : '?';
        }
    }

    ubSync();
    ubPreviewLogo(document.getElementById('ubLogoUrl').value.trim());
</script>