@using COROLA_RENTACAR.EntityLayer.Entities
@using COROLA_RENTACAR.EntityLayer.Enums
@using System.Text.Json
@model List<COROLA_RENTACAR.EntityLayer.Entities.Reservation>

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    var latestCustomers = ViewBag.LatestCustomers as List<Customer> ?? new List<Customer>();

    var totalCars = Convert.ToInt32(ViewBag.TotalCars ?? 0);
    var availableCars = Convert.ToInt32(ViewBag.AvailableCars ?? 0);
    var unavailableCars = Convert.ToInt32(ViewBag.UnavailableCars ?? 0);

    var totalCustomers = Convert.ToInt32(ViewBag.TotalCustomers ?? 0);
    var pendingLicenses = Convert.ToInt32(ViewBag.PendingLicenses ?? 0);
    var approvedLicenses = Convert.ToInt32(ViewBag.ApprovedLicenses ?? 0);
    var rejectedLicenses = Convert.ToInt32(ViewBag.RejectedLicenses ?? 0);

    var totalReservations = Convert.ToInt32(ViewBag.TotalReservations ?? 0);
    var pendingReservations = Convert.ToInt32(ViewBag.PendingReservations ?? 0);
    var approvedReservations = Convert.ToInt32(ViewBag.ApprovedReservations ?? 0);
    var rejectedReservations = Convert.ToInt32(ViewBag.RejectedReservations ?? 0);
    var cancelledReservations = Convert.ToInt32(ViewBag.CancelledReservations ?? 0);

    var todayReservations = Convert.ToInt32(ViewBag.TodayReservations ?? 0);
    var activeReservations = Convert.ToInt32(ViewBag.ActiveReservations ?? 0);

    var totalRevenue = Convert.ToDecimal(ViewBag.TotalRevenue ?? 0);
    var monthlyRevenue = Convert.ToDecimal(ViewBag.MonthlyRevenue ?? 0);

    var monthLabels = ViewBag.MonthLabels as List<string> ?? new List<string>();
    var monthlyRevenueData = ViewBag.MonthlyRevenueData as List<decimal> ?? new List<decimal>();
    var monthlyReservationData = ViewBag.MonthlyReservationData as List<int> ?? new List<int>();

    var reservationStatusLabels = ViewBag.ReservationStatusLabels as List<string> ?? new List<string>();
    var reservationStatusData = ViewBag.ReservationStatusData as List<int> ?? new List<int>();

    var carAvailabilityLabels = ViewBag.CarAvailabilityLabels as List<string> ?? new List<string>();
    var carAvailabilityData = ViewBag.CarAvailabilityData as List<int> ?? new List<int>();

    var categoryLabels = ViewBag.CategoryLabels as List<string> ?? new List<string>();
    var categoryData = ViewBag.CategoryData as List<int> ?? new List<int>();

    var approvalRate = totalReservations == 0 ? 0 : approvedReservations * 100 / totalReservations;
    var availabilityRate = totalCars == 0 ? 0 : availableCars * 100 / totalCars;
    var licenseApprovalRate = totalCustomers == 0 ? 0 : approvedLicenses * 100 / totalCustomers;
}

<style>
    .dash-root {
        padding: 28px;
        color: #e2e8f0;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    .dash-breadcrumb {
        font-size: 12px;
        color: #7a8499;
        margin-bottom: 8px;
    }

    .dash-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .dash-title {
        font-size: 28px;
        font-weight: 900;
        margin: 0;
    }

    .dash-subtitle {
        color: #7a8499;
        font-size: 13px;
        margin-top: 6px;
    }

    .dash-date {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 12px;
        padding: 10px 14px;
        color: #7a8499;
        font-size: 13px;
        font-weight: 700;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(180px, 1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .stat-card {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 18px;
        padding: 18px;
        position: relative;
        overflow: hidden;
    }

        .stat-card::after {
            content: "";
            position: absolute;
            right: -28px;
            top: -28px;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: rgba(232,255,71,.06);
        }

    .stat-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        position: relative;
        z-index: 1;
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 13px;
        background: rgba(232,255,71,.12);
        color: #e8ff47;
        display: grid;
        place-items: center;
        font-size: 20px;
    }

    .stat-label {
        color: #7a8499;
        font-size: 12px;
        font-weight: 800;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 900;
        position: relative;
        z-index: 1;
        line-height: 1;
    }

    .stat-note {
        color: #7a8499;
        font-size: 12px;
        margin-top: 8px;
        position: relative;
        z-index: 1;
    }

    .chart-grid {
        display: grid;
        grid-template-columns: 1.35fr .65fr;
        gap: 18px;
        margin-bottom: 20px;
    }

    .chart-grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        margin-bottom: 20px;
    }

    .dash-card {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 18px;
        overflow: hidden;
    }

    .dash-card-header {
        padding: 18px;
        border-bottom: 1px solid rgba(255,255,255,.07);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .dash-card-title {
        margin: 0;
        font-size: 16px;
        font-weight: 900;
    }

    .dash-card-link {
        color: #e8ff47;
        text-decoration: none;
        font-size: 12px;
        font-weight: 900;
    }

    .dash-card-body {
        padding: 18px;
    }

    .chart-box {
        height: 310px;
    }

    .chart-box-small {
        height: 250px;
    }

    .health-list {
        display: grid;
        gap: 16px;
    }

    .health-item {
        display: grid;
        gap: 8px;
    }

    .health-head {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        font-weight: 800;
    }

    .health-track {
        height: 9px;
        border-radius: 999px;
        background: #1a1e2a;
        overflow: hidden;
    }

    .health-fill {
        height: 100%;
        border-radius: 999px;
        background: #e8ff47;
    }

    .row-list {
        display: grid;
        gap: 12px;
    }

    .dash-row {
        background: #1a1e2a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 14px;
        padding: 13px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
    }

    .row-title {
        font-weight: 900;
        font-size: 14px;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .row-subtitle {
        color: #7a8499;
        font-size: 12px;
        line-height: 1.5;
    }

    .dash-status {
        border-radius: 8px;
        padding: 5px 9px;
        font-size: 11px;
        font-weight: 900;
        white-space: nowrap;
    }

        .dash-status.pending {
            background: rgba(255,181,71,.14);
            color: #ffb547;
            border: 1px solid rgba(255,181,71,.25);
        }

        .dash-status.approved {
            background: rgba(48,224,161,.14);
            color: #30e0a1;
            border: 1px solid rgba(48,224,161,.25);
        }

        .dash-status.rejected,
        .dash-status.cancelled {
            background: rgba(255,82,89,.14);
            color: #ff5259;
            border: 1px solid rgba(255,82,89,.25);
        }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-top: 20px;
    }

    .quick-action {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        color: #e2e8f0;
        border-radius: 16px;
        padding: 18px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 13px;
        transition: .2s;
    }

        .quick-action:hover {
            color: #e8ff47;
            border-color: rgba(232,255,71,.32);
            background: rgba(232,255,71,.05);
        }

    .quick-icon {
        width: 42px;
        height: 42px;
        border-radius: 13px;
        background: rgba(232,255,71,.12);
        color: #e8ff47;
        display: grid;
        place-items: center;
        font-size: 20px;
    }

    .quick-title {
        font-size: 14px;
        font-weight: 900;
    }

    .quick-subtitle {
        color: #7a8499;
        font-size: 12px;
        margin-top: 3px;
    }

    .empty-state {
        padding: 30px;
        text-align: center;
        color: #7a8499;
    }

    @@media(max-width: 1200px) {
        .stats-grid,
        .chart-grid-3 {
            grid-template-columns: repeat(2, 1fr);
        }

        .chart-grid {
            grid-template-columns: 1fr;
        }

        .quick-actions {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 650px) {
        .stats-grid,
        .chart-grid-3,
        .quick-actions {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dash-root">

    <div class="dash-breadcrumb">
        Admin Panel › Dashboard
    </div>

    <div class="dash-header">
        <div>
            <h1 class="dash-title">Dashboard</h1>
            <p class="dash-subtitle">Operational analytics for COROLA Rent A Car management.</p>
        </div>

        <div class="dash-date">
            @DateTime.Now.ToString("dd MMM yyyy, HH:mm", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-head">
                <div class="stat-icon">🚗</div>
                <div class="stat-label">CARS</div>
            </div>
            <div class="stat-value">@totalCars</div>
            <div class="stat-note">@availableCars available / @unavailableCars unavailable</div>
        </div>

        <div class="stat-card">
            <div class="stat-head">
                <div class="stat-icon">📋</div>
                <div class="stat-label">RESERVATIONS</div>
            </div>
            <div class="stat-value">@totalReservations</div>
            <div class="stat-note">@pendingReservations pending / @activeReservations active today</div>
        </div>

        <div class="stat-card">
            <div class="stat-head">
                <div class="stat-icon">👤</div>
                <div class="stat-label">CUSTOMERS</div>
            </div>
            <div class="stat-value">@totalCustomers</div>
            <div class="stat-note">@pendingLicenses pending license checks</div>
        </div>

        <div class="stat-card">
            <div class="stat-head">
                <div class="stat-icon">₺</div>
                <div class="stat-label">REVENUE</div>
            </div>
            <div class="stat-value">@totalRevenue.ToString("N0") ₺</div>
            <div class="stat-note">@monthlyRevenue.ToString("N0") ₺ this month</div>
        </div>
    </div>

    <div class="chart-grid">
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Revenue Trend</h2>
                <a href="/Admin/Reservation/ReservationList" class="dash-card-link">View Reservations</a>
            </div>
            <div class="dash-card-body">
                <div class="chart-box">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>

        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Business Health</h2>
                <span class="dash-card-link">@approvalRate% approval</span>
            </div>
            <div class="dash-card-body">
                <div class="health-list">
                    <div class="health-item">
                        <div class="health-head">
                            <span>Car Availability</span>
                            <span>@availabilityRate%</span>
                        </div>
                        <div class="health-track">
                            <div class="health-fill" style="width:@availabilityRate%"></div>
                        </div>
                    </div>

                    <div class="health-item">
                        <div class="health-head">
                            <span>Reservation Approval</span>
                            <span>@approvalRate%</span>
                        </div>
                        <div class="health-track">
                            <div class="health-fill" style="width:@approvalRate%"></div>
                        </div>
                    </div>

                    <div class="health-item">
                        <div class="health-head">
                            <span>License Approval</span>
                            <span>@licenseApprovalRate%</span>
                        </div>
                        <div class="health-track">
                            <div class="health-fill" style="width:@licenseApprovalRate%"></div>
                        </div>
                    </div>

                    <div style="background:#1a1e2a;border-radius:14px;padding:14px;margin-top:6px;">
                        <div style="font-size:12px;color:#7a8499;">Today’s Reservations</div>
                        <div style="font-size:24px;font-weight:900;margin-top:4px;">@todayReservations</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="chart-grid-3">
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Reservation Status</h2>
            </div>
            <div class="dash-card-body">
                <div class="chart-box-small">
                    <canvas id="reservationStatusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Car Availability</h2>
            </div>
            <div class="dash-card-body">
                <div class="chart-box-small">
                    <canvas id="carAvailabilityChart"></canvas>
                </div>
            </div>
        </div>

        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Cars by Category</h2>
            </div>
            <div class="dash-card-body">
                <div class="chart-box-small">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="chart-grid">
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Latest Reservations</h2>
                <a href="/Admin/Reservation/ReservationList" class="dash-card-link">View All</a>
            </div>

            <div class="dash-card-body">
                @if (Model == null || !Model.Any())
                {
                    <div class="empty-state">
                        No reservations found.
                    </div>
                }
                else
                {
                    <div class="row-list">
                        @foreach (var reservation in Model)
                        {
                            var carName = $"{reservation.Car?.Brand?.BrandName} {reservation.Car?.Model}";
                            var customerName = $"{reservation.Customer?.FirstName} {reservation.Customer?.LastName}";
                            var statusText = reservation.ReservationStatus.ToString();
                            var statusClass = statusText.ToLower();

                            <div class="dash-row">
                                <div>
                                    <div class="row-title">@carName</div>
                                    <div class="row-subtitle">
                                        @customerName • @reservation.PickupDate.ToString("dd MMM", System.Globalization.CultureInfo.GetCultureInfo("en-US")) -
                                        @reservation.ReturnDate.ToString("dd MMM", System.Globalization.CultureInfo.GetCultureInfo("en-US")) •
                                        @reservation.TotalPrice.ToString("N0") ₺
                                    </div>
                                </div>

                                <span class="dash-status @statusClass">@statusText</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Latest Customers</h2>
                <a href="/Admin/Customer/CustomerList" class="dash-card-link">View All</a>
            </div>

            <div class="dash-card-body">
                @if (!latestCustomers.Any())
                {
                    <div class="empty-state">
                        No customers found.
                    </div>
                }
                else
                {
                    <div class="row-list">
                        @foreach (var customer in latestCustomers)
                        {
                            var fullName = $"{customer.FirstName} {customer.LastName}";
                            var licenseStatus = customer.DriverLicenseVerificationStatus.ToString();
                            var licenseClass = licenseStatus.ToLower();

                            <div class="dash-row">
                                <div>
                                    <div class="row-title">@fullName</div>
                                    <div class="row-subtitle">
                                        @customer.Email • @customer.Phone
                                    </div>
                                </div>

                                <span class="dash-status @licenseClass">@licenseStatus</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="quick-actions">
        <a href="/Admin/Car/CreateCar" class="quick-action">
            <div class="quick-icon">🚗</div>
            <div>
                <div class="quick-title">Add Car</div>
                <div class="quick-subtitle">Create new vehicle</div>
            </div>
        </a>

        <a href="/Admin/Reservation/CreateReservation" class="quick-action">
            <div class="quick-icon">📋</div>
            <div>
                <div class="quick-title">New Reservation</div>
                <div class="quick-subtitle">Create booking</div>
            </div>
        </a>

        <a href="/Admin/Customer/CustomerList" class="quick-action">
            <div class="quick-icon">🪪</div>
            <div>
                <div class="quick-title">Verify Licenses</div>
                <div class="quick-subtitle">Review customers</div>
            </div>
        </a>

        <a href="/Admin/Reservation/ReservationList" class="quick-action">
            <div class="quick-icon">✅</div>
            <div>
                <div class="quick-title">Approve Requests</div>
                <div class="quick-subtitle">Manage reservations</div>
            </div>
        </a>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const monthLabels = @Html.Raw(JsonSerializer.Serialize(monthLabels));
    const monthlyRevenueData = @Html.Raw(JsonSerializer.Serialize(monthlyRevenueData));
    const monthlyReservationData = @Html.Raw(JsonSerializer.Serialize(monthlyReservationData));

    const reservationStatusLabels = @Html.Raw(JsonSerializer.Serialize(reservationStatusLabels));
    const reservationStatusData = @Html.Raw(JsonSerializer.Serialize(reservationStatusData));

    const carAvailabilityLabels = @Html.Raw(JsonSerializer.Serialize(carAvailabilityLabels));
    const carAvailabilityData = @Html.Raw(JsonSerializer.Serialize(carAvailabilityData));

    const categoryLabels = @Html.Raw(JsonSerializer.Serialize(categoryLabels));
    const categoryData = @Html.Raw(JsonSerializer.Serialize(categoryData));

    const chartColors = [
        '#e8ff47',
        '#30e0a1',
        '#ff5259',
        '#ffb547',
        '#4f8dff',
        '#9b5cff',
        '#ff7a45'
    ];

    Chart.defaults.color = '#9aa4b8';
    Chart.defaults.borderColor = 'rgba(255,255,255,.08)';
    Chart.defaults.font.family = "'DM Sans', 'Segoe UI', sans-serif";

    function hasData(data) {
        return data && data.some(x => Number(x) > 0);
    }

    function renderEmptyChartMessage(canvasId, message) {
        const canvas = document.getElementById(canvasId);
        const parent = canvas.parentElement;

        parent.innerHTML = `
            <div style="height:100%;display:flex;align-items:center;justify-content:center;text-align:center;color:#7a8499;font-size:13px;font-weight:800;">
                ${message}
            </div>
        `;
    }

    if (hasData(monthlyRevenueData) || hasData(monthlyReservationData)) {
        new Chart(document.getElementById('revenueChart'), {
            type: 'line',
            data: {
                labels: monthLabels,
                datasets: [
                    {
                        label: 'Revenue',
                        data: monthlyRevenueData,
                        tension: .4,
                        fill: true,
                        borderWidth: 3,
                        pointRadius: 4,
                        borderColor: '#e8ff47',
                        backgroundColor: 'rgba(232,255,71,.12)',
                        pointBackgroundColor: '#e8ff47',
                        pointBorderColor: '#11131a'
                    },
                    {
                        label: 'Reservations',
                        data: monthlyReservationData,
                        tension: .4,
                        borderWidth: 2,
                        pointRadius: 4,
                        yAxisID: 'y1',
                        borderColor: '#4f8dff',
                        backgroundColor: 'rgba(79,141,255,.12)',
                        pointBackgroundColor: '#4f8dff',
                        pointBorderColor: '#11131a'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false
                },
                plugins: {
                    legend: {
                        labels: {
                            usePointStyle: true,
                            boxWidth: 8,
                            boxHeight: 8
                        }
                    },
                    tooltip: {
                        backgroundColor: '#0b0d12',
                        titleColor: '#ffffff',
                        bodyColor: '#e2e8f0',
                        borderColor: 'rgba(255,255,255,.12)',
                        borderWidth: 1,
                        callbacks: {
                            label: function (context) {
                                if (context.dataset.label === 'Revenue') {
                                    return 'Revenue: ' + Number(context.raw).toLocaleString('en-US') + ' ₺';
                                }

                                return 'Reservations: ' + context.raw;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: {
                            color: 'rgba(255,255,255,.04)'
                        }
                    },
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(255,255,255,.06)'
                        },
                        ticks: {
                            callback: function (value) {
                                return Number(value).toLocaleString('en-US') + ' ₺';
                            }
                        }
                    },
                    y1: {
                        beginAtZero: true,
                        position: 'right',
                        grid: {
                            drawOnChartArea: false
                        },
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    } else {
        renderEmptyChartMessage('revenueChart', 'No revenue or reservation data yet.');
    }

    if (hasData(reservationStatusData)) {
        new Chart(document.getElementById('reservationStatusChart'), {
            type: 'doughnut',
            data: {
                labels: reservationStatusLabels,
                datasets: [{
                    data: reservationStatusData,
                    backgroundColor: [
                        '#ffb547',
                        '#30e0a1',
                        '#ff5259',
                        '#7a8499'
                    ],
                    hoverBackgroundColor: [
                        '#ffc86d',
                        '#55efbb',
                        '#ff7379',
                        '#9aa4b8'
                    ],
                    borderColor: '#13161e',
                    borderWidth: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '62%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            boxWidth: 8,
                            boxHeight: 8,
                            padding: 16
                        }
                    },
                    tooltip: {
                        backgroundColor: '#0b0d12',
                        titleColor: '#ffffff',
                        bodyColor: '#e2e8f0',
                        borderColor: 'rgba(255,255,255,.12)',
                        borderWidth: 1
                    }
                }
            }
        });
    } else {
        renderEmptyChartMessage('reservationStatusChart', 'No reservation status data yet.');
    }

    if (hasData(carAvailabilityData)) {
        new Chart(document.getElementById('carAvailabilityChart'), {
            type: 'doughnut',
            data: {
                labels: carAvailabilityLabels,
                datasets: [{
                    data: carAvailabilityData,
                    backgroundColor: [
                        '#30e0a1',
                        '#ff5259'
                    ],
                    hoverBackgroundColor: [
                        '#55efbb',
                        '#ff7379'
                    ],
                    borderColor: '#13161e',
                    borderWidth: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '62%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            boxWidth: 8,
                            boxHeight: 8,
                            padding: 16
                        }
                    },
                    tooltip: {
                        backgroundColor: '#0b0d12',
                        titleColor: '#ffffff',
                        bodyColor: '#e2e8f0',
                        borderColor: 'rgba(255,255,255,.12)',
                        borderWidth: 1
                    }
                }
            }
        });
    } else {
        renderEmptyChartMessage('carAvailabilityChart', 'No car availability data yet.');
    }

    if (hasData(categoryData)) {
        new Chart(document.getElementById('categoryChart'), {
            type: 'bar',
            data: {
                labels: categoryLabels,
                datasets: [{
                    label: 'Cars',
                    data: categoryData,
                    backgroundColor: categoryLabels.map((_, index) => chartColors[index % chartColors.length]),
                    borderWidth: 0,
                    borderRadius: 8,
                    barThickness: categoryLabels.length === 1 ? 42 : undefined,
                    maxBarThickness: 54
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                indexAxis: categoryLabels.length > 4 ? 'y' : 'x',
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: '#0b0d12',
                        titleColor: '#ffffff',
                        bodyColor: '#e2e8f0',
                        borderColor: 'rgba(255,255,255,.12)',
                        borderWidth: 1
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(255,255,255,.06)'
                        },
                        ticks: {
                            precision: 0
                        }
                    },
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(255,255,255,.06)'
                        },
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    } else {
        renderEmptyChartMessage('categoryChart', 'No category data yet.');
    }
</script>