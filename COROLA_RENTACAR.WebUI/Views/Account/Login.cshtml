@model COROLA_RENTACAR.WebUI.Models.AdminLoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin Login | COROLA Rent A Car</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg, #0f172a, #111827, #1e293b);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #111827;
        }

        .login-wrapper {
            width: 100%;
            max-width: 440px;
            padding: 24px;
        }

        .login-card {
            background: #ffffff;
            border-radius: 22px;
            padding: 34px;
            box-shadow: 0 28px 80px rgba(0, 0, 0, 0.35);
        }

        .brand-box {
            margin-bottom: 28px;
            text-align: center;
        }

        .brand-title {
            font-size: 27px;
            font-weight: 800;
            letter-spacing: -0.6px;
            margin-bottom: 6px;
            color: #111827;
        }

        .brand-subtitle {
            color: #6b7280;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin-bottom: 7px;
            font-size: 13px;
            font-weight: 700;
            color: #374151;
        }

        input[type="email"],
        input[type="password"] {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 12px;
            padding: 13px 14px;
            font-size: 14px;
            outline: none;
            transition: 0.2s;
        }

            input[type="email"]:focus,
            input[type="password"]:focus {
                border-color: #111827;
                box-shadow: 0 0 0 4px rgba(17, 24, 39, 0.08);
            }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            color: #4b5563;
            font-size: 14px;
        }

        .login-button {
            width: 100%;
            border: none;
            border-radius: 14px;
            padding: 14px;
            background: #111827;
            color: #ffffff;
            font-weight: 800;
            font-size: 15px;
            cursor: pointer;
            transition: 0.2s;
        }

            .login-button:hover {
                background: #000000;
                transform: translateY(-1px);
            }

        .validation-summary-errors {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 18px;
            font-size: 14px;
        }

        .field-validation-error {
            display: block;
            margin-top: 6px;
            color: #dc2626;
            font-size: 12px;
            font-weight: 600;
        }

        .footer-text {
            margin-top: 22px;
            text-align: center;
            font-size: 12px;
            color: #6b7280;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="brand-box">
                <div class="brand-title">COROLA Rent</div>
                <div class="brand-subtitle">Admin Management Panel</div>
            </div>

            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly"></div>

                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email" type="email" autocomplete="username" placeholder="admin@corola.com" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password" autocomplete="current-password" placeholder="Enter your password" />
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="remember-row">
                    <input asp-for="RememberMe" />
                    <label asp-for="RememberMe" style="margin:0;font-weight:600;">Remember me</label>
                </div>

                <button type="submit" class="login-button">Sign In</button>
            </form>

            <div class="footer-text">
                Protected admin access · COROLA Rent A Car
            </div>
        </div>
    </div>
</body>
</html>