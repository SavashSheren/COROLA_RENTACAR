@model COROLA_RENTACAR.EntityLayer.Entities.Brand

@{
    ViewData["Title"] = "Create Brand";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --bg-dark: #0d0f14;
        --bg-dark2: #13161e;
        --bg-dark3: #1a1e2a;
        --accent: #e8ff47;
        --accent-dim: rgba(232,255,71,.12);
        --danger: #ff5259;
        --success: #30e0a1;
        --border: rgba(255,255,255,.07);
        --text: #e2e8f0;
        --text-muted: #7a8499;
        --radius: 14px;
    }

    .cb-root {
        padding: 28px;
        color: var(--text);
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    .cb-breadcrumb {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 8px;
    }

        .cb-breadcrumb a {
            color: var(--text-muted);
            text-decoration: none;
        }

            .cb-breadcrumb a:hover {
                color: var(--accent);
            }

    .cb-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .cb-page-title {
        font-size: 26px;
        font-weight: 800;
        margin: 0;
        color: var(--text);
    }

    .cb-page-subtitle {
        color: var(--text-muted);
        font-size: 13px;
        margin-top: 6px;
    }

    .cb-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 18px;
    }

    .cb-card,
    .cb-sidebar-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin-bottom: 16px;
        overflow: hidden;
    }

    .cb-card-head,
    .cb-sidebar-head {
        padding: 16px 18px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 800;
    }

    .cb-card-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: grid;
        place-items: center;
    }

        .cb-card-icon.yellow {
            background: var(--accent-dim);
            color: var(--accent);
        }

        .cb-card-icon.green {
            background: rgba(48,224,161,.12);
            color: var(--success);
        }

    .cb-card-title {
        font-size: 15px;
        font-weight: 800;
    }

    .cb-card-subtitle {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 3px;
    }

    .cb-card-body,
    .cb-sidebar-body {
        padding: 18px;
    }

    .cb-field {
        margin-bottom: 16px;
    }

        .cb-field label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 7px;
        }

    .cb-required {
        color: var(--danger);
    }

    .cb-field input {
        width: 100%;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        padding: 11px 13px;
        outline: none;
    }

        .cb-field input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-dim);
        }

    .cb-hint {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 6px;
    }

    .cb-validation-summary {
        background: rgba(255,82,89,.1);
        border: 1px solid rgba(255,82,89,.25);
        color: var(--danger);
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        font-size: 13px;
    }

        .cb-validation-summary ul {
            margin: 0;
            padding-left: 18px;
        }

    .cb-img-preview {
        height: 145px;
        border-radius: 12px;
        background: var(--bg-dark3);
        border: 1px dashed var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        color: var(--text-muted);
        text-align: center;
    }

        .cb-img-preview img {
            max-width: 120px;
            max-height: 100px;
            object-fit: contain;
            display: none;
        }

    .cb-toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .cb-toggle-label {
        font-weight: 800;
    }

    .cb-toggle-desc {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    .cb-toggle {
        width: 54px;
        height: 30px;
        border-radius: 999px;
        background: rgba(255,82,89,.25);
        padding: 4px;
        cursor: pointer;
        transition: .2s;
    }

        .cb-toggle.on {
            background: rgba(48,224,161,.35);
        }

    .cb-toggle-knob {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #fff;
        transition: .2s;
    }

    .cb-toggle.on .cb-toggle-knob {
        transform: translateX(24px);
    }

    .btn-accent,
    .btn-outline {
        border-radius: 10px;
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
    }

    .btn-accent {
        background: var(--accent);
        color: #0d0f14;
        border: none;
    }

    .btn-outline {
        background: var(--bg-dark3);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .cb-action-bar {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .cb-live-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        border-bottom: 1px solid var(--border);
        padding: 10px 0;
        font-size: 13px;
    }

    .cb-live-key {
        color: var(--text-muted);
    }

    .cb-live-val {
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        text-align: right;
    }

    .cb-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        border-radius: 8px;
        padding: 4px 9px;
        font-size: 12px;
        font-weight: 800;
    }

        .cb-status-pill.active {
            background: rgba(48,224,161,.12);
            color: var(--success);
        }

        .cb-status-pill.passive {
            background: rgba(255,82,89,.12);
            color: var(--danger);
        }

    @@media(max-width: 900px) {
        .cb-layout {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="cb-root">

    <div class="cb-breadcrumb">
        Vehicle Management <span>›</span>
        <a href="/Admin/Brand/BrandList">Brand List</a>
        <span>›</span>
        <span>Add New Brand</span>
    </div>

    <div class="cb-page-header">
        <div>
            <h1 class="cb-page-title">Add New Brand</h1>
            <p class="cb-page-subtitle">Define a new vehicle brand in the system.</p>
        </div>

        <div style="display:flex;gap:10px;">
            <a href="/Admin/Brand/BrandList" class="btn-outline">✕ Cancel</a>
            <button type="button" class="btn-accent" onclick="cbSubmit()">＋ Save Brand</button>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="cb-validation-summary">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form id="cbForm" action="/Admin/Brand/CreateBrand" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="cb-layout">

            <div>
                <div class="cb-card">
                    <div class="cb-card-head">
                        <div class="cb-card-icon yellow">🏷️</div>
                        <div>
                            <div class="cb-card-title">Brand Information</div>
                            <div class="cb-card-subtitle">Enter brand name and logo URL</div>
                        </div>
                    </div>

                    <div class="cb-card-body">

                        <div class="cb-field">
                            <label>Brand Name <span class="cb-required">*</span></label>
                            <input type="text"
                                   id="cbBrandName"
                                   name="BrandName"
                                   value="@Model?.BrandName"
                                   placeholder="e.g. Toyota, BMW, Audi"
                                   maxlength="50"
                                   oninput="cbSync()"
                                   autocomplete="off" />
                        </div>

                        <div class="cb-field">
                            <label>Logo URL</label>
                            <input type="text"
                                   id="cbLogoUrl"
                                   name="LogoUrl"
                                   value="@Model?.LogoUrl"
                                   placeholder="https://example.com/logo.png"
                                   oninput="cbSync(); cbPreviewLogo(this.value)"
                                   autocomplete="off" />
                            <div class="cb-hint">Supported formats: PNG, SVG, WebP, JPG</div>
                        </div>

                        <div class="cb-img-preview">
                            <img id="cbPreviewTag" src="" alt="Logo Preview" />
                            <div id="cbPreviewPlaceholder">
                                <div style="font-size:32px;">🖼️</div>
                                <div>Enter a logo URL<br />to see preview</div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="cb-card">
                    <div class="cb-card-head">
                        <div class="cb-card-icon green">⚡</div>
                        <div>
                            <div class="cb-card-title">Status</div>
                            <div class="cb-card-subtitle">Brand visibility in the system</div>
                        </div>
                    </div>

                    <div class="cb-card-body">
                        <div class="cb-toggle-row">
                            <div>
                                <div class="cb-toggle-label" id="cbToggleLabel">Active</div>
                                <div class="cb-toggle-desc">Brand is visible and selectable in the system</div>
                            </div>

                            <div class="cb-toggle on" id="cbToggle" onclick="cbToggleStatus()">
                                <div class="cb-toggle-knob"></div>
                            </div>
                        </div>

                        <input type="hidden" id="cbStatusInput" name="Status" value="true" />
                    </div>
                </div>

                <div class="cb-action-bar">
                    <a href="/Admin/Brand/BrandList" class="btn-outline">✕ Cancel</a>
                    <button type="button" class="btn-accent" onclick="cbSubmit()">＋ Save Brand</button>
                </div>
            </div>

            <div>
                <div class="cb-sidebar-card">
                    <div class="cb-sidebar-head">📋 Live Preview</div>

                    <div class="cb-sidebar-body">
                        <div style="height:100px;background:var(--bg-dark3);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;overflow:hidden;">
                            <img id="cbSidePreview"
                                 src=""
                                 alt=""
                                 style="height:64px;object-fit:contain;display:none;" />

                            <div id="cbSidePlaceholder"
                                 style="width:64px;height:64px;border-radius:12px;background:var(--bg-dark2);display:grid;place-items:center;font-size:26px;font-weight:700;color:var(--text-muted);">
                                ?
                            </div>
                        </div>

                        <div class="cb-live-row">
                            <span class="cb-live-key">Brand Name</span>
                            <span class="cb-live-val" id="sumName">—</span>
                        </div>

                        <div class="cb-live-row">
                            <span class="cb-live-key">Logo URL</span>
                            <span class="cb-live-val" id="sumLogo">—</span>
                        </div>

                        <div class="cb-live-row" style="border-bottom:none;">
                            <span class="cb-live-key">Status</span>
                            <span id="sumStatus">
                                <span class="cb-status-pill active">Active</span>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="cb-sidebar-card">
                    <div class="cb-sidebar-head">💡 Tips</div>
                    <div class="cb-sidebar-body">
                        <div class="cb-live-row">
                            <span class="cb-live-key">BrandId</span>
                            <span>Assigned automatically</span>
                        </div>
                        <div class="cb-live-row">
                            <span class="cb-live-key">Logo</span>
                            <span>Optional</span>
                        </div>
                        <div class="cb-live-row" style="border-bottom:none;">
                            <span class="cb-live-key">Status</span>
                            <span>Default active</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<script>
    let cbStatus = true;

    function cbSubmit() {
        const name = document.getElementById('cbBrandName').value.trim();

        if (!name) {
            alert("Brand name is required.");
            return;
        }

        document.getElementById('cbForm').submit();
    }

    function cbToggleStatus() {
        cbStatus = !cbStatus;

        document.getElementById('cbStatusInput').value = cbStatus ? 'true' : 'false';
        document.getElementById('cbToggle').classList.toggle('on', cbStatus);
        document.getElementById('cbToggleLabel').innerText = cbStatus ? 'Active' : 'Inactive';

        cbSync();
    }

    function cbPreviewLogo(value) {
        const preview = document.getElementById('cbPreviewTag');
        const placeholder = document.getElementById('cbPreviewPlaceholder');
        const sidePreview = document.getElementById('cbSidePreview');
        const sidePlaceholder = document.getElementById('cbSidePlaceholder');

        if (!value) {
            preview.style.display = 'none';
            placeholder.style.display = 'block';

            sidePreview.style.display = 'none';
            sidePlaceholder.style.display = 'grid';
            return;
        }

        preview.src = value;
        preview.style.display = 'block';
        placeholder.style.display = 'none';

        sidePreview.src = value;
        sidePreview.style.display = 'block';
        sidePlaceholder.style.display = 'none';
    }

    function cbSync() {
        const name = document.getElementById('cbBrandName').value.trim();
        const logo = document.getElementById('cbLogoUrl').value.trim();

        document.getElementById('sumName').innerText = name || '—';
        document.getElementById('sumLogo').innerText = logo || '—';

        document.getElementById('sumStatus').innerHTML = cbStatus
            ? '<span class="cb-status-pill active">Active</span>'
            : '<span class="cb-status-pill passive">Inactive</span>';

        const sidePlaceholder = document.getElementById('cbSidePlaceholder');
        if (sidePlaceholder && !logo) {
            sidePlaceholder.innerText = name ? name.charAt(0).toUpperCase() : '?';
        }
    }

    cbSync();
</script>