@{
    Layout = null;
    ViewData["Title"] = "Access Denied";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Access Denied | COROLA Rent A Car</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
            background: #111827;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .box {
            max-width: 460px;
            padding: 36px;
            background: #ffffff;
            color: #111827;
            border-radius: 22px;
            text-align: center;
            box-shadow: 0 24px 70px rgba(0,0,0,.35);
        }

        h1 {
            margin: 0 0 12px;
            font-size: 30px;
        }

        p {
            color: #6b7280;
            margin-bottom: 24px;
        }

        a {
            display: inline-block;
            padding: 12px 18px;
            border-radius: 12px;
            background: #111827;
            color: #ffffff;
            text-decoration: none;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <div class="box">
        <h1>Access Denied</h1>
        <p>You do not have permission to access this area.</p>
        <a href="/Account/Login">Back to Login</a>
    </div>
</body>
</html>