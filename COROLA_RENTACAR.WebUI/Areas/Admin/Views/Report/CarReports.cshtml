@using COROLA_RENTACAR.EntityLayer.Entities
@using System.Text.Json
@model List<COROLA_RENTACAR.EntityLayer.Entities.Car>

@{
    ViewData["Title"] = "Car Reports";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    var totalCars = Model?.Count ?? 0;
    var availableCars = Model?.Count(x => x.IsAvailable) ?? 0;
    var unavailableCars = Model?.Count(x => !x.IsAvailable) ?? 0;

    var averageDailyPrice = Model != null && Model.Any()
        ? Model.Average(x => x.DailyPrice)
        : 0;

    var highestPriceCar = Model?
        .OrderByDescending(x => x.DailyPrice)
        .FirstOrDefault();

    var categoryGroups = Model?
        .GroupBy(x => x.Category != null ? x.Category.CategoryName : "Uncategorized")
        .OrderByDescending(x => x.Count())
        .ToList() ?? new List<IGrouping<string, Car>>();

    var brandGroups = Model?
        .GroupBy(x => x.Brand != null ? x.Brand.BrandName : "Unknown")
        .OrderByDescending(x => x.Count())
        .Take(8)
        .ToList() ?? new List<IGrouping<string, Car>>();

    var categoryLabels = categoryGroups.Select(x => x.Key).ToList();
    var categoryData = categoryGroups.Select(x => x.Count()).ToList();

    var brandLabels = brandGroups.Select(x => x.Key).ToList();
    var brandData = brandGroups.Select(x => x.Count()).ToList();

    var availabilityLabels = new List<string> { "Available", "Unavailable" };
    var availabilityData = new List<int> { availableCars, unavailableCars };
}

<style>
    .report-root {
        padding: 28px;
        color: #e2e8f0;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    .report-breadcrumb {
        color: #7a8499;
        font-size: 12px;
        margin-bottom: 8px;
    }

    .report-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 22px;
    }

    .report-title {
        font-size: 28px;
        font-weight: 900;
        margin: 0;
    }

    .report-subtitle {
        color: #7a8499;
        font-size: 13px;
        margin-top: 6px;
    }

    .btn-accent {
        background: #e8ff47;
        color: #0d0f14;
        border: none;
        border-radius: 10px;
        padding: 11px 16px;
        font-size: 13px;
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(180px, 1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .stat-card {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 18px;
        padding: 18px;
    }

    .stat-label {
        color: #7a8499;
        font-size: 12px;
        font-weight: 900;
        margin-bottom: 12px;
    }

    .stat-value {
        font-size: 27px;
        font-weight: 900;
        line-height: 1;
    }

    .stat-note {
        color: #7a8499;
        font-size: 12px;
        margin-top: 8px;
    }

    .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 20px;
    }

    .report-card {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 18px;
        overflow: hidden;
    }

    .report-card-header {
        padding: 18px;
        border-bottom: 1px solid rgba(255,255,255,.07);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .report-card-title {
        margin: 0;
        font-size: 16px;
        font-weight: 900;
    }

    .report-card-body {
        padding: 18px;
    }

    .chart-box {
        height: 310px;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 940px;
    }

        .report-table th {
            color: #7a8499;
            background: #0f1219;
            font-size: 12px;
            text-align: left;
            padding: 13px;
            border-bottom: 1px solid rgba(255,255,255,.07);
        }

        .report-table td {
            padding: 13px;
            border-bottom: 1px solid rgba(255,255,255,.06);
            font-size: 13px;
        }

    .status-badge {
        border-radius: 8px;
        padding: 5px 9px;
        font-size: 11px;
        font-weight: 900;
        white-space: nowrap;
    }

        .status-badge.available {
            color: #30e0a1;
            background: rgba(48,224,161,.14);
            border: 1px solid rgba(48,224,161,.25);
        }

        .status-badge.unavailable {
            color: #ff5259;
            background: rgba(255,82,89,.14);
            border: 1px solid rgba(255,82,89,.25);
        }

    @@media(max-width: 1100px) {
        .stats-grid,
        .chart-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width: 700px) {
        .stats-grid,
        .chart-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="report-root">

    <div class="report-breadcrumb">
        Admin Panel › Reports › Car Reports
    </div>

    <div class="report-header">
        <div>
            <h1 class="report-title">Car Reports</h1>
            <p class="report-subtitle">Analyze vehicle inventory, availability, brand distribution and category performance.</p>
        </div>

        <a href="/Admin/Car/CarList" class="btn-accent">
            View Cars
        </a>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">TOTAL CARS</div>
            <div class="stat-value">@totalCars</div>
            <div class="stat-note">Registered vehicles</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">AVAILABLE CARS</div>
            <div class="stat-value">@availableCars</div>
            <div class="stat-note">Ready for rental</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">UNAVAILABLE CARS</div>
            <div class="stat-value">@unavailableCars</div>
            <div class="stat-note">Not currently available</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">AVG DAILY PRICE</div>
            <div class="stat-value">@averageDailyPrice.ToString("N0") ₺</div>
            <div class="stat-note">Average rental price</div>
        </div>
    </div>

    <div class="chart-grid">
        <div class="report-card">
            <div class="report-card-header">
                <h2 class="report-card-title">Cars by Category</h2>
            </div>

            <div class="report-card-body">
                <div class="chart-box">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header">
                <h2 class="report-card-title">Cars by Brand</h2>
            </div>

            <div class="report-card-body">
                <div class="chart-box">
                    <canvas id="brandChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="chart-grid">
        <div class="report-card">
            <div class="report-card-header">
                <h2 class="report-card-title">Availability Distribution</h2>
            </div>

            <div class="report-card-body">
                <div class="chart-box">
                    <canvas id="availabilityChart"></canvas>
                </div>
            </div>
        </div>

        <div class="report-card">
            <div class="report-card-header">
                <h2 class="report-card-title">Highest Priced Car</h2>
            </div>

            <div class="report-card-body">
                @if (highestPriceCar == null)
                {
                    <div style="color:#7a8499;text-align:center;padding:40px;">
                        No car data found.
                    </div>
                }
                else
                {
                    <div style="display:grid;gap:13px;">
                        <div style="font-size:24px;font-weight:900;">
                            @highestPriceCar.Brand?.BrandName @highestPriceCar.Model
                        </div>

                        <div style="color:#7a8499;">
                            Plate: @highestPriceCar.PlateNumber
                        </div>

                        <div style="color:#7a8499;">
                            Category: @highestPriceCar.Category?.CategoryName
                        </div>

                        <div style="font-size:30px;font-weight:900;color:#e8ff47;margin-top:8px;">
                            @highestPriceCar.DailyPrice.ToString("N0") ₺ / day
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="report-card">
        <div class="report-card-header">
            <h2 class="report-card-title">Car Report Detail</h2>
        </div>

        <div class="report-card-body">
            <div class="table-wrap">
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Car</th>
                            <th>Plate</th>
                            <th>Category</th>
                            <th>Fuel</th>
                            <th>Transmission</th>
                            <th>Status</th>
                            <th>Daily Price</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="8" style="text-align:center;color:#7a8499;padding:35px;">
                                    No car report data found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                var carName = $"{item.Brand?.BrandName} {item.Model}";
                                var statusClass = item.IsAvailable ? "available" : "unavailable";
                                var statusText = item.IsAvailable ? "Available" : "Unavailable";

                                <tr>
                                    <td>#@item.CarId</td>
                                    <td>@carName</td>
                                    <td>@item.PlateNumber</td>
                                    <td>@item.Category?.CategoryName</td>
                                    <td>@item.FuelType</td>
                                    <td>@item.TransmissionType</td>
                                    <td>
                                        <span class="status-badge @statusClass">
                                            @statusText
                                        </span>
                                    </td>
                                    <td>@item.DailyPrice.ToString("N0") ₺</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const categoryLabels = @Html.Raw(JsonSerializer.Serialize(categoryLabels));
    const categoryData = @Html.Raw(JsonSerializer.Serialize(categoryData));

    const brandLabels = @Html.Raw(JsonSerializer.Serialize(brandLabels));
    const brandData = @Html.Raw(JsonSerializer.Serialize(brandData));

    const availabilityLabels = @Html.Raw(JsonSerializer.Serialize(availabilityLabels));
    const availabilityData = @Html.Raw(JsonSerializer.Serialize(availabilityData));

    const chartColors = [
        '#e8ff47',
        '#30e0a1',
        '#4f8dff',
        '#ffb547',
        '#ff5259',
        '#9b5cff',
        '#ff7a45',
        '#7a8499'
    ];

    Chart.defaults.color = '#9aa4b8';
    Chart.defaults.borderColor = 'rgba(255,255,255,.08)';
    Chart.defaults.font.family = "'DM Sans', 'Segoe UI', sans-serif";

    new Chart(document.getElementById('categoryChart'), {
        type: 'bar',
        data: {
            labels: categoryLabels,
            datasets: [{
                label: 'Cars',
                data: categoryData,
                backgroundColor: categoryLabels.map((_, index) => chartColors[index % chartColors.length]),
                borderRadius: 8,
                borderWidth: 0,
                maxBarThickness: 58
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: categoryLabels.length > 4 ? 'y' : 'x',
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                x: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                },
                y: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                }
            }
        }
    });

    new Chart(document.getElementById('brandChart'), {
        type: 'bar',
        data: {
            labels: brandLabels,
            datasets: [{
                label: 'Cars',
                data: brandData,
                backgroundColor: brandLabels.map((_, index) => chartColors[index % chartColors.length]),
                borderRadius: 8,
                borderWidth: 0,
                maxBarThickness: 58
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: brandLabels.length > 4 ? 'y' : 'x',
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                x: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                },
                y: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                }
            }
        }
    });

    new Chart(document.getElementById('availabilityChart'), {
        type: 'doughnut',
        data: {
            labels: availabilityLabels,
            datasets: [{
                data: availabilityData,
                backgroundColor: [
                    '#30e0a1',
                    '#ff5259'
                ],
                borderColor: '#13161e',
                borderWidth: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '62%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        usePointStyle: true,
                        boxWidth: 8,
                        boxHeight: 8,
                        padding: 16
                    }
                }
            }
        }
    });
</script>