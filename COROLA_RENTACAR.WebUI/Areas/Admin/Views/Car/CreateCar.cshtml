@using COROLA_RENTACAR.EntityLayer.Entities
@model COROLA_RENTACAR.EntityLayer.Entities.Car

@{
    ViewData["Title"] = "Create Car";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    var brands = ViewBag.Brands as List<Brand> ?? new List<Brand>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<style>
    .car-form-root {
        padding: 28px;
        color: #e2e8f0;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    .car-form-breadcrumb {
        font-size: 12px;
        color: #7a8499;
        margin-bottom: 8px;
    }

        .car-form-breadcrumb a {
            color: #7a8499;
            text-decoration: none;
        }

            .car-form-breadcrumb a:hover {
                color: #e8ff47;
            }

    .car-form-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .car-form-title {
        font-size: 26px;
        font-weight: 800;
        margin: 0;
    }

    .car-form-subtitle {
        color: #7a8499;
        font-size: 13px;
        margin-top: 6px;
    }

    .car-form-card {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 16px;
    }

    .car-form-card-header {
        padding: 18px;
        border-bottom: 1px solid rgba(255,255,255,.07);
        font-weight: 800;
    }

    .car-form-card-body {
        padding: 18px;
    }

    .car-form-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .car-field {
        margin-bottom: 16px;
    }

        .car-field.full {
            grid-column: 1 / -1;
        }

        .car-field label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 7px;
        }

        .car-field input,
        .car-field select {
            width: 100%;
            background: #1a1e2a;
            border: 1px solid rgba(255,255,255,.07);
            border-radius: 10px;
            color: #e2e8f0;
            padding: 11px 13px;
            outline: none;
        }

            .car-field input:focus,
            .car-field select:focus {
                border-color: #e8ff47;
                box-shadow: 0 0 0 3px rgba(232,255,71,.12);
            }

    .car-required {
        color: #ff5259;
    }

    .car-validation {
        background: rgba(255,82,89,.1);
        border: 1px solid rgba(255,82,89,.25);
        color: #ff5259;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        font-size: 13px;
    }

    .car-preview {
        height: 220px;
        border-radius: 14px;
        background: #1a1e2a;
        border: 1px dashed rgba(255,255,255,.07);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        color: #7a8499;
        text-align: center;
    }

        .car-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

    .car-toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .car-toggle-label {
        font-weight: 800;
    }

    .car-toggle-desc {
        font-size: 12px;
        color: #7a8499;
        margin-top: 4px;
    }

    .car-toggle {
        width: 54px;
        height: 30px;
        border-radius: 999px;
        background: rgba(255,82,89,.25);
        padding: 4px;
        cursor: pointer;
        transition: .2s;
    }

        .car-toggle.on {
            background: rgba(48,224,161,.35);
        }

    .car-toggle-knob {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #fff;
        transition: .2s;
    }

    .car-toggle.on .car-toggle-knob {
        transform: translateX(24px);
    }

    .btn-accent,
    .btn-outline {
        border-radius: 10px;
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
    }

    .btn-accent {
        background: #e8ff47;
        color: #0d0f14;
        border: none;
    }

    .btn-outline {
        background: #1a1e2a;
        color: #e2e8f0;
        border: 1px solid rgba(255,255,255,.07);
    }

    .car-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 20px;
    }

    @@media(max-width: 1100px) {
        .car-form-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 700px) {
        .car-form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="car-form-root">

    <div class="car-form-breadcrumb">
        Vehicle Management ›
        <a href="/Admin/Car/CarList">Car List</a>
        › Add New Car
    </div>

    <div class="car-form-header">
        <div>
            <h1 class="car-form-title">Add New Car</h1>
            <p class="car-form-subtitle">Define a new rental car in the system.</p>
        </div>

        <a href="/Admin/Car/CarList" class="btn-outline">✕ Cancel</a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="car-validation">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form id="carForm" action="/Admin/Car/CreateCar" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="car-form-card">
            <div class="car-form-card-header">🚗 Basic Car Information</div>

            <div class="car-form-card-body">
                <div class="car-form-grid">
                    <div class="car-field">
                        <label>Brand <span class="car-required">*</span></label>
                        <select name="BrandId" id="brandId">
                            <option value="0">Select brand</option>
                            @foreach (var brand in brands)
                            {
                                if (brand.BrandId == Model.BrandId)
                                {
                                    <option value="@brand.BrandId" selected>@brand.BrandName</option>
                                }
                                else
                                {
                                    <option value="@brand.BrandId">@brand.BrandName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="car-field">
                        <label>Category <span class="car-required">*</span></label>
                        <select name="CategoryId" id="categoryId">
                            <option value="0">Select category</option>
                            @foreach (var category in categories)
                            {
                                if (category.CategoryId == Model.CategoryId)
                                {
                                    <option value="@category.CategoryId" selected>@category.CategoryName</option>
                                }
                                else
                                {
                                    <option value="@category.CategoryId">@category.CategoryName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="car-field">
                        <label>Model <span class="car-required">*</span></label>
                        <input type="text" name="Model" id="model" value="@Model.Model" placeholder="e.g. Corolla" maxlength="50" />
                    </div>

                    <div class="car-field">
                        <label>Model Year <span class="car-required">*</span></label>
                        <input type="number" name="ModelYear" id="modelYear" value="@Model.ModelYear" />
                    </div>

                    <div class="car-field">
                        <label>Plate Number <span class="car-required">*</span></label>
                        <input type="text" name="PlateNumber" id="plateNumber" value="@Model.PlateNumber" placeholder="e.g. 34 CRL 001" maxlength="20" />
                    </div>

                    <div class="car-field">
                        <label>Daily Price <span class="car-required">*</span></label>
                        <input type="number" name="DailyPrice" id="dailyPrice" value="@Model.DailyPrice" step="0.01" min="0" />
                    </div>

                    <div class="car-field">
                        <label>Seat Count <span class="car-required">*</span></label>
                        <input type="number" name="SeatCount" id="seatCount" value="@Model.SeatCount" min="1" max="12" />
                    </div>

                    <div class="car-field">
                        <label>Luggage Capacity <span class="car-required">*</span></label>
                        <input type="number" name="LuggageCapacity" id="luggageCapacity" value="@Model.LuggageCapacity" min="0" max="10" />
                    </div>

                    <div class="car-field">
                        <label>Mileage <span class="car-required">*</span></label>
                        <input type="number" name="Mileage" id="mileage" value="@Model.Mileage" min="0" />
                    </div>

                    <div class="car-field">
                        <label>Fuel Type <span class="car-required">*</span></label>
                        <select name="FuelType" id="fuelType">
                            <option value="">Select fuel type</option>
                            <option value="Gasoline">Gasoline</option>
                            <option value="Diesel">Diesel</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="Electric">Electric</option>
                        </select>
                    </div>

                    <div class="car-field">
                        <label>Transmission Type <span class="car-required">*</span></label>
                        <select name="TransmissionType" id="transmissionType">
                            <option value="">Select transmission</option>
                            <option value="Automatic">Automatic</option>
                            <option value="Manual">Manual</option>
                        </select>
                    </div>

                    <div class="car-field full">
                        <label>Image URL <span class="car-required">*</span></label>
                        <input type="text" name="ImageUrl" id="imageUrl" value="@Model.ImageUrl" placeholder="https://example.com/car.jpg" oninput="previewCarImage(this.value)" />
                    </div>

                    <div class="car-field full">
                        <div class="car-preview">
                            <img id="carPreviewImage" src="" alt="Car Preview" />
                            <div id="carPreviewPlaceholder">
                                <div style="font-size:38px;">🚗</div>
                                <div>Enter image URL to see preview</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="car-form-card">
            <div class="car-form-card-header">⚡ Availability</div>

            <div class="car-form-card-body">
                <div class="car-toggle-row">
                    <div>
                        <div class="car-toggle-label" id="availabilityLabel">Available</div>
                        <div class="car-toggle-desc">Car can be selected for reservation.</div>
                    </div>

                    <div class="car-toggle on" id="availabilityToggle" onclick="toggleAvailability()">
                        <div class="car-toggle-knob"></div>
                    </div>
                </div>

                <input type="hidden" id="isAvailableInput" name="IsAvailable" value="true" />
            </div>
        </div>

        <div class="car-actions">
            <a href="/Admin/Car/CarList" class="btn-outline">Cancel</a>
            <button type="button" class="btn-accent" onclick="submitCarForm()">＋ Save Car</button>
        </div>
    </form>
</div>

<script>
    let isAvailable = true;

    function toggleAvailability() {
        isAvailable = !isAvailable;

        document.getElementById('isAvailableInput').value = isAvailable ? 'true' : 'false';
        document.getElementById('availabilityToggle').classList.toggle('on', isAvailable);
        document.getElementById('availabilityLabel').innerText = isAvailable ? 'Available' : 'Unavailable';
    }

    function previewCarImage(value) {
        const image = document.getElementById('carPreviewImage');
        const placeholder = document.getElementById('carPreviewPlaceholder');

        if (!value) {
            image.style.display = 'none';
            placeholder.style.display = 'block';
            return;
        }

        image.src = value;
        image.style.display = 'block';
        placeholder.style.display = 'none';
    }

    function submitCarForm() {
        const brandId = document.getElementById('brandId').value;
        const categoryId = document.getElementById('categoryId').value;
        const model = document.getElementById('model').value.trim();
        const plateNumber = document.getElementById('plateNumber').value.trim();
        const imageUrl = document.getElementById('imageUrl').value.trim();

        if (brandId === "0" || categoryId === "0" || !model || !plateNumber || !imageUrl) {
            alert("Please fill all required fields.");
            return;
        }

        document.getElementById('carForm').submit();
    }

    previewCarImage(document.getElementById('imageUrl').value);
</script>