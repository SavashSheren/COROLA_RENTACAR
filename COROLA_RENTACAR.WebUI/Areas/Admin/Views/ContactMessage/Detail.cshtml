@model COROLA_RENTACAR.EntityLayer.Entities.ContactMessage

@{
    ViewData["Title"] = "Contact Message Detail";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid">

    <div class="card border-0 shadow-sm mb-4" style="border-radius:18px;">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-1">Message Detail</h3>
                <p class="text-muted mb-0">Review the selected contact message.</p>
            </div>

            <a asp-area="Admin"
               asp-controller="ContactMessage"
               asp-action="Inbox"
               class="btn btn-outline-dark">
                Back to Inbox
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:18px;">
        <div class="card-body p-4">

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="text-muted small">Full Name</label>
                    <h5>@Model.FullName</h5>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small">Email</label>
                    <h5>@Model.Email</h5>
                </div>

                <div class="col-md-6 mt-3">
                    <label class="text-muted small">Phone</label>
                    <h5>@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</h5>
                </div>

                <div class="col-md-6 mt-3">
                    <label class="text-muted small">Created Date</label>
                    <h5>@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</h5>
                </div>
            </div>

            <hr />

            <div class="mb-4">
                <label class="text-muted small">Subject</label>
                <h4>@Model.Subject</h4>
            </div>

            <div class="p-4 bg-light border" style="border-radius:16px; white-space:pre-line; line-height:1.8;">
                @Model.Message
            </div>

            <div class="mt-4 d-flex gap-2">
                <form asp-area="Admin"
                      asp-controller="ContactMessage"
                      asp-action="MarkAsUnread"
                      asp-route-id="@Model.ContactMessageId"
                      method="post">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-warning">
                        Mark as Unread
                    </button>
                </form>

                <form asp-area="Admin"
                      asp-controller="ContactMessage"
                      asp-action="Delete"
                      asp-route-id="@Model.ContactMessageId"
                      method="post"
                      onsubmit="return confirm('Are you sure you want to delete this message?');">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-danger">
                        Delete Message
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>