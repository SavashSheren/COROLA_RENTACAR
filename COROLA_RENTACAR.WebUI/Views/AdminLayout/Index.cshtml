@{
    Layout = null;

    var currentController = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "";
    var pageTitle = ViewData["Title"]?.ToString() ?? "Admin Panel";

    Func<string, string> isControllerActive = controller =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    Func<string[], string> isMenuOpen = controllers =>
        Array.Exists(controllers, controller => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)) ? "open" : "";

    var vehicleMenuOpen = isMenuOpen(new[] { "Brand", "Category", "Location", "Car", "CarImage" });
    var reservationMenuOpen = isMenuOpen(new[] { "Reservation" });
    var customerMenuOpen = isMenuOpen(new[] { "Customer" });
    var contentMenuOpen = isMenuOpen(new[] { "Banner", "About", "Service", "Testimonial", "FAQ", "ContactInfo" });
    var reportMenuOpen = isMenuOpen(new[] { "Report", "PdfReport" });
    var aiMenuOpen = isMenuOpen(new[] { "AI", "AiContent" });
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@pageTitle | COROLA Rent A Car Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --sidebar-w: 270px;
            --sidebar-collapsed-w: 76px;
            --navbar-h: 66px;
            --bg-dark: #0d0f14;
            --bg-dark2: #13161e;
            --bg-dark3: #1a1e2a;
            --bg-dark4: #202637;
            --accent: #e8ff47;
            --accent-dim: rgba(232,255,71,.12);
            --accent-border: rgba(232,255,71,.28);
            --blue: #4f8dff;
            --blue-dim: rgba(79,141,255,.12);
            --danger: #ff5259;
            --success: #30e0a1;
            --warning: #ffb547;
            --border: rgba(255,255,255,.075);
            --text: #e2e8f0;
            --text-muted: #7a8499;
            --radius: 12px;
            --radius-lg: 18px;
            --shadow: 0 12px 40px rgba(0,0,0,.42);
            --transition: .22s cubic-bezier(.4,0,.2,1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        html, body {
            min-height: 100%;
        }

        body {
            margin: 0;
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-dark);
            color: var(--text);
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
        }

        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--bg-dark4);
            border-radius: 999px;
        }

        .admin-shell {
            display: flex;
            min-height: 100vh;
            background: radial-gradient(circle at top right, rgba(232,255,71,.035), transparent 34%), radial-gradient(circle at bottom left, rgba(79,141,255,.035), transparent 32%), var(--bg-dark);
        }

        .admin-sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: rgba(19,22,30,.98);
            border-right: 1px solid var(--border);
            position: fixed;
            inset: 0 auto 0 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: width var(--transition), transform var(--transition);
            overflow: hidden;
        }

            .admin-sidebar.collapsed {
                width: var(--sidebar-collapsed-w);
            }

                .admin-sidebar.collapsed .admin-brand-text,
                .admin-sidebar.collapsed .admin-section-title,
                .admin-sidebar.collapsed .admin-nav-label,
                .admin-sidebar.collapsed .admin-sub-arrow,
                .admin-sidebar.collapsed .admin-sub-menu,
                .admin-sidebar.collapsed .admin-sidebar-footer span {
                    display: none !important;
                }

                .admin-sidebar.collapsed .admin-brand {
                    justify-content: center;
                    padding-inline: 0;
                }

                .admin-sidebar.collapsed .admin-nav-link {
                    justify-content: center;
                    padding-inline: 0;
                }

                .admin-sidebar.collapsed .admin-nav-icon {
                    margin: 0;
                }

        .admin-brand {
            height: var(--navbar-h);
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 20px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .admin-brand-icon {
            width: 40px;
            height: 40px;
            border-radius: 13px;
            display: grid;
            place-items: center;
            background: var(--accent);
            color: var(--bg-dark);
            box-shadow: 0 0 0 5px var(--accent-dim);
            flex-shrink: 0;
        }

            .admin-brand-icon i {
                font-size: 20px;
            }

        .admin-brand-title {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -.3px;
            line-height: 1;
            white-space: nowrap;
        }

            .admin-brand-title span {
                color: var(--accent);
            }

        .admin-brand-subtitle {
            margin-top: 4px;
            font-size: 11px;
            color: var(--text-muted);
            white-space: nowrap;
        }

        .admin-sidebar-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 14px 10px;
        }

        .admin-section-title {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text-muted);
            padding: 16px 12px 7px;
            font-weight: 700;
            white-space: nowrap;
        }

        .admin-nav-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .admin-nav-item {
            list-style: none;
            margin: 2px 0;
        }

        .admin-nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            min-height: 42px;
            padding: 10px 12px;
            border-radius: var(--radius);
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 600;
            transition: background var(--transition), color var(--transition), border-color var(--transition);
            cursor: pointer;
        }

            .admin-nav-link:hover {
                background: var(--bg-dark3);
                color: var(--text);
            }

            .admin-nav-link.active {
                background: var(--accent-dim);
                color: var(--accent);
                border: 1px solid var(--accent-border);
            }

        .admin-nav-icon {
            width: 20px;
            display: inline-flex;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .admin-nav-label {
            flex: 1;
            white-space: nowrap;
        }

        .admin-sub-arrow {
            font-size: 12px;
            transition: transform var(--transition);
        }

        .admin-nav-item.open > .admin-nav-link .admin-sub-arrow {
            transform: rotate(90deg);
        }

        .admin-sub-menu {
            list-style: none;
            padding: 5px 0 5px 42px;
            margin: 0;
            max-height: 0;
            overflow: hidden;
            transition: max-height .28s ease;
        }

        .admin-nav-item.open > .admin-sub-menu {
            max-height: 420px;
        }

        .admin-sub-menu a {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border-radius: 9px;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            transition: color var(--transition), background var(--transition);
        }

            .admin-sub-menu a::before {
                content: '';
                width: 5px;
                height: 5px;
                border-radius: 999px;
                background: currentColor;
                opacity: .55;
            }

            .admin-sub-menu a:hover {
                color: var(--text);
                background: var(--bg-dark3);
            }

            .admin-sub-menu a.active {
                color: var(--accent);
                background: rgba(232,255,71,.055);
            }

        .admin-sidebar-footer {
            border-top: 1px solid var(--border);
            padding: 12px 10px;
            flex-shrink: 0;
        }

            .admin-sidebar-footer a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 12px;
                border-radius: var(--radius);
                color: var(--danger);
                font-size: 14px;
                font-weight: 700;
                transition: background var(--transition);
            }

                .admin-sidebar-footer a:hover {
                    background: rgba(255,82,89,.08);
                }

        .admin-main {
            margin-left: var(--sidebar-w);
            flex: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left var(--transition);
            min-width: 0;
        }

            .admin-main.expanded {
                margin-left: var(--sidebar-collapsed-w);
            }

        .admin-topbar {
            height: var(--navbar-h);
            background: rgba(19,22,30,.94);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 900;
        }

        .admin-toggle-btn,
        .admin-topbar-btn {
            width: 39px;
            height: 39px;
            border: 1px solid var(--border);
            background: var(--bg-dark3);
            color: var(--text-muted);
            border-radius: 11px;
            display: grid;
            place-items: center;
            cursor: pointer;
            transition: background var(--transition), color var(--transition), border var(--transition);
        }

            .admin-toggle-btn:hover,
            .admin-topbar-btn:hover {
                background: var(--accent-dim);
                color: var(--accent);
                border-color: var(--accent-border);
            }

        .admin-page-meta {
            min-width: 0;
        }

        .admin-page-kicker {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 800;
            line-height: 1;
        }

        .admin-page-title {
            margin-top: 4px;
            font-size: 15px;
            font-weight: 800;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .admin-search {
            flex: 1;
            max-width: 360px;
            position: relative;
            margin-left: 16px;
        }

            .admin-search i {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 15px;
            }

            .admin-search input {
                width: 100%;
                height: 39px;
                background: var(--bg-dark3);
                border: 1px solid var(--border);
                border-radius: 11px;
                color: var(--text);
                padding: 8px 12px 8px 38px;
                font-size: 13px;
                outline: none;
            }

                .admin-search input:focus {
                    border-color: var(--accent-border);
                    box-shadow: 0 0 0 3px var(--accent-dim);
                }

        .admin-actions {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .admin-dot {
            position: absolute;
            top: 7px;
            right: 7px;
            width: 8px;
            height: 8px;
            background: var(--danger);
            border-radius: 50%;
            border: 2px solid var(--bg-dark2);
        }

        .admin-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--bg-dark3);
            border: 1px solid var(--border);
            border-radius: 13px;
            padding: 6px 11px 6px 6px;
            color: var(--text);
            cursor: pointer;
        }

        .admin-avatar {
            width: 29px;
            height: 29px;
            border-radius: 9px;
            background: linear-gradient(135deg, var(--blue), var(--accent));
            color: var(--bg-dark);
            display: grid;
            place-items: center;
            font-size: 12px;
            font-weight: 900;
        }

        .admin-profile-name {
            font-size: 13px;
            font-weight: 800;
            line-height: 1.1;
        }

        .admin-profile-role {
            margin-top: 2px;
            font-size: 11px;
            color: var(--text-muted);
            line-height: 1;
        }

        .dropdown-menu {
            background: var(--bg-dark2) !important;
            border: 1px solid var(--border) !important;
            border-radius: var(--radius) !important;
            box-shadow: var(--shadow) !important;
            padding: 7px !important;
        }

        .dropdown-header {
            color: var(--text-muted) !important;
            font-size: 11px !important;
            text-transform: uppercase;
            letter-spacing: .9px;
            font-weight: 800;
        }

        .dropdown-item {
            color: var(--text-muted) !important;
            border-radius: 9px !important;
            padding: 9px 11px !important;
            font-size: 13px !important;
            display: flex;
            align-items: center;
            gap: 9px;
        }

            .dropdown-item:hover {
                background: var(--bg-dark3) !important;
                color: var(--text) !important;
            }

        .dropdown-divider {
            border-color: var(--border) !important;
        }

        .admin-content {
            flex: 1;
            min-width: 0;
        }

        .admin-toast {
            position: fixed;
            right: 18px;
            bottom: 18px;
            z-index: 5000;
            background: var(--bg-dark2);
            border: 1px solid var(--border);
            color: var(--text);
            border-radius: var(--radius);
            padding: 12px 14px;
            box-shadow: var(--shadow);
            display: none;
            min-width: 260px;
            font-size: 13px;
        }

            .admin-toast.show {
                display: block;
            }

        .admin-mobile-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.62);
            z-index: 990;
            backdrop-filter: blur(2px);
        }

            .admin-mobile-overlay.show {
                display: block;
            }

        @@media (max-width: 992px) {
            .admin-search {
                display: none;
            }
        }

        @@media (max-width: 768px) {
            .admin-sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-w);
            }

                .admin-sidebar.mobile-open {
                    transform: translateX(0);
                }

            .admin-main,
            .admin-main.expanded {
                margin-left: 0;
            }

            .admin-topbar {
                padding: 0 14px;
            }

            .admin-page-kicker {
                display: none;
            }

            .admin-profile-name,
            .admin-profile-role {
                display: none;
            }
        }
    </style>
</head>

<body>
    <div class="admin-mobile-overlay" id="adminMobileOverlay" onclick="closeMobileSidebar()"></div>

    <div class="admin-shell">
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="admin-brand">
                <div class="admin-brand-icon">
                    <i class="bi bi-car-front-fill"></i>
                </div>

                <div class="admin-brand-text">
                    <div class="admin-brand-title">COROLA <span>Rent</span></div>
                    <div class="admin-brand-subtitle">Admin Management Panel</div>
                </div>
            </div>

            <nav class="admin-sidebar-nav">
                <ul class="admin-nav-list">

                    <li class="admin-nav-item">
                        <a href="/Admin/Dashboard/Index" class="admin-nav-link @isControllerActive("Dashboard")">
                            <i class="bi bi-grid-1x2-fill admin-nav-icon"></i>
                            <span class="admin-nav-label">Dashboard</span>
                        </a>
                    </li>

                    <div class="admin-section-title">Vehicle Management</div>

                    <li class="admin-nav-item has-submenu @vehicleMenuOpen" id="menuVehicle">
                        <a href="javascript:void(0)" class="admin-nav-link">
                            <i class="bi bi-car-front admin-nav-icon"></i>
                            <span class="admin-nav-label">Vehicle Management</span>
                            <i class="bi bi-chevron-right admin-sub-arrow"></i>
                        </a>

                        <ul class="admin-sub-menu">
                            <li>
                                <a href="/Admin/Brand/BrandList" class="@isControllerActive("Brand")">Brand Management</a>
                            </li>
                            <li>
                                <a href="/Admin/Category/CategoryList" class="@isControllerActive("Category")">Category Management</a>
                            </li>
                            <li>
                                <a href="/Admin/Location/LocationList" class="@isControllerActive("Location")">Location Management</a>
                            </li>
                            <li>
                                <a href="/Admin/Car/CarList" class="@isControllerActive("Car")">Car Management</a>
                            </li>
                            <li>
                                <a href="/Admin/CarImage/CarImageList" class="@isControllerActive("CarImage")">Car Images</a>
                            </li>
                        </ul>
                    </li>

                    <li class="admin-nav-item has-submenu @reservationMenuOpen" id="menuReservation">
                        <a href="javascript:void(0)" class="admin-nav-link">
                            <i class="bi bi-calendar-check admin-nav-icon"></i>
                            <span class="admin-nav-label">Reservations</span>
                            <i class="bi bi-chevron-right admin-sub-arrow"></i>
                        </a>

                        <ul class="admin-sub-menu">
                            <li>
                                <a href="/Admin/Reservation/ReservationList" class="@isControllerActive("Reservation")">Reservation List</a>
                            </li>
                            <li>
                                <a href="/Admin/ReservationCalendar/Index" class="nav-sub-link">
                                     Reservation Calendar
                                </a>
                            </li>
                          
                            <li>
                                <a href="/Admin/Reservation/PendingReservations">Pending Reservations</a>
                            </li>
                            <li>
                                <a href="/Admin/Reservation/ApprovedReservations">Approved Reservations</a>
                            </li>
                            <li>
                                <a href="/Admin/Reservation/RejectedReservations">Rejected Reservations</a>
                            </li>
                            <li>
                                <a href="/Admin/Reservation/CancelledReservations" class="nav-sub-link">
                                     Cancelled Reservations
                                </a>
                            </li>
                        </ul>
                    </li>

                    <div class="admin-section-title">CRM</div>

                    <li class="admin-nav-item has-submenu @customerMenuOpen" id="menuCustomer">
                        <a href="javascript:void(0)" class="admin-nav-link">
                            <i class="bi bi-people admin-nav-icon"></i>
                            <span class="admin-nav-label">Customers</span>
                            <i class="bi bi-chevron-right admin-sub-arrow"></i>
                        </a>

                        <ul class="admin-sub-menu">
                            <li>
                                <a href="/Admin/Customer/CustomerList" class="@isControllerActive("Customer")">Customer List</a>
                            </li>
                        </ul>
                    </li>

                    <div class="admin-section-title">Productivity</div>

                    <li class="admin-nav-item has-submenu @reportMenuOpen" id="menuReports">
                        <a href="javascript:void(0)" class="admin-nav-link">
                            <i class="bi bi-bar-chart-line admin-nav-icon"></i>
                            <span class="admin-nav-label">Reports</span>
                            <i class="bi bi-chevron-right admin-sub-arrow"></i>
                        </a>

                        <ul class="admin-sub-menu">
                            <li>
                                <a href="/Admin/Report/ReservationReports" class="@isControllerActive("Report")">
                                    Reservation Reports
                                </a>
                            </li>

                            <li>
                                <a href="/Admin/Report/CarReports" class="@isControllerActive("Report")">
                                    Car Reports
                                </a>
                            </li>

                            <li>
                                <a href="/Admin/Report/PdfReports" class="@isControllerActive("Report")">
                                    PDF Reports
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="admin-nav-item has-submenu @aiMenuOpen" id="menuAi">
                        <a href="javascript:void(0)" class="admin-nav-link">
                            <i class="bi bi-stars admin-nav-icon"></i>
                            <span class="admin-nav-label">AI Tools</span>
                            <i class="bi bi-chevron-right admin-sub-arrow"></i>
                        </a>

                        <ul class="admin-sub-menu">
                            <li>
                                <a href="/Admin/AI/ContentGenerator" class="@isControllerActive("AI")">AI Content Generator</a>
                            </li>
                            <li>
                                <a href="/Admin/AI/CarDescription">Car Description AI</a>
                            </li>
                        </ul>
                    </li>

                    <div class="admin-section-title">System</div>

                    <li class="admin-nav-item">
                        <a href="/Admin/Settings/Index" class="admin-nav-link @isControllerActive("Settings")">
                            <i class="bi bi-gear admin-nav-icon"></i>
                            <span class="admin-nav-label">Settings</span>
                        </a>
                    </li>

                    <li class="admin-nav-item">
                        <a href="/" target="_blank" class="admin-nav-link">
                            <i class="bi bi-globe2 admin-nav-icon"></i>
                            <span class="admin-nav-label">View Website</span>
                        </a>
                    </li>

                </ul>
            </nav>

            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" style="background:none;border:none;padding:0;color:inherit;cursor:pointer;">
                    Log Out
                </button>
            </form>
        </aside>

        <div class="admin-main" id="adminMain">
            <header class="admin-topbar">
                <button class="admin-toggle-btn" type="button" onclick="toggleSidebar()" title="Toggle sidebar">
                    <i class="bi bi-layout-sidebar"></i>
                </button>

                <div class="admin-page-meta">
                    <div class="admin-page-kicker">Admin Panel</div>
                    <div class="admin-page-title">@pageTitle</div>
                </div>

                <div class="admin-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search in admin panel..." onkeydown="adminSearchEnter(event)" />
                </div>

                <div class="admin-actions">
                    <div class="dropdown">
                        <button class="admin-topbar-btn position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-bell"></i>
                            <span class="admin-dot"></span>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">Notifications</h6></li>
                            <li><a class="dropdown-item" href="/Admin/Reservation/ReservationList"><i class="bi bi-calendar-plus"></i> New reservations</a></li>
                            <li><a class="dropdown-item" href="/Admin/Car/CarList"><i class="bi bi-car-front"></i> Vehicle updates</a></li>
                            <li><a class="dropdown-item" href="/Admin/Report/ReservationReports"><i class="bi bi-bar-chart"></i> Reports</a></li>
                        </ul>
                    </div>

                    <div class="dropdown">
                        <button class="admin-topbar-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-lightning-charge"></i>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">Quick Actions</h6></li>
                            <li><a class="dropdown-item" href="/Admin/Brand/CreateBrand"><i class="bi bi-plus-circle"></i> Add Brand</a></li>
                            <li><a class="dropdown-item" href="/Admin/Car/CreateCar"><i class="bi bi-plus-circle"></i> Add Car</a></li>
                            <li><a class="dropdown-item" href="/Admin/AI/ContentGenerator"><i class="bi bi-stars"></i> Generate Content</a></li>
                        </ul>
                    </div>

                    <div class="dropdown">
                        <button class="admin-profile" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="admin-avatar">CR</span>
                            <span class="d-none d-sm-block text-start">
                                <span class="admin-profile-name d-block">Admin Manager</span>
                                <span class="admin-profile-role d-block">Super Admin</span>
                            </span>
                            <i class="bi bi-chevron-down" style="font-size:11px;color:var(--text-muted);"></i>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">Account</h6></li>
                            <li><a class="dropdown-item" href="/Admin/Profile/Index"><i class="bi bi-person"></i> My Profile</a></li>
                            <li><a class="dropdown-item" href="/Admin/Settings/Index"><i class="bi bi-gear"></i> Settings</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="showAdminToast('Logout flow will be added later.');"><i class="bi bi-box-arrow-right"></i> Log Out</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="admin-toast" id="adminToast"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('adminSidebar');
            const main = document.getElementById('adminMain');
            const overlay = document.getElementById('adminMobileOverlay');
            const isMobile = window.innerWidth <= 768;

            if (isMobile) {
                sidebar.classList.toggle('mobile-open');
                overlay.classList.toggle('show');
                return;
            }

            sidebar.classList.toggle('collapsed');
            main.classList.toggle('expanded');

            localStorage.setItem('corola_admin_sidebar_collapsed', sidebar.classList.contains('collapsed') ? 'true' : 'false');
        }

        function closeMobileSidebar() {
            document.getElementById('adminSidebar').classList.remove('mobile-open');
            document.getElementById('adminMobileOverlay').classList.remove('show');
        }

        function showAdminToast(message) {
            const toast = document.getElementById('adminToast');
            toast.innerText = message;
            toast.classList.add('show');

            setTimeout(() => {
                toast.classList.remove('show');
            }, 2600);
        }

        function adminSearchEnter(event) {
            if (event.key === 'Enter') {
                const value = event.target.value.trim();

                if (!value) {
                    showAdminToast('Enter a keyword to search.');
                    return;
                }

                showAdminToast('Search module will be connected later: ' + value);
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.getElementById('adminSidebar');
            const main = document.getElementById('adminMain');

            if (localStorage.getItem('corola_admin_sidebar_collapsed') === 'true' && window.innerWidth > 768) {
                sidebar.classList.add('collapsed');
                main.classList.add('expanded');
            }

            document.querySelectorAll('.admin-nav-item.has-submenu > .admin-nav-link').forEach(link => {
                link.addEventListener('click', function () {
                    const item = this.closest('.admin-nav-item');
                    item.classList.toggle('open');
                });
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>