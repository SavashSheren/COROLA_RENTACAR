@{
    ViewData["Title"] = "Reservation Submitted";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<section class="page-title centred" style="background-image: url(/carola/assets/images/background/page-title.jpg);">
    <div class="container">
        <div class="content-box">
            <h1>Reservation Submitted</h1>
            <ul class="bread-crumb clearfix">
                <li><a href="/">Home</a></li>
                <li>Success</li>
            </ul>
        </div>
    </div>
</section>

<section class="pt_120 pb_120">
    <div class="container">
        <div style="max-width:760px;margin:0 auto;background:#fff;border:1px solid #eee;border-radius:22px;padding:50px;text-align:center;box-shadow:0 15px 35px rgba(0,0,0,.06);">
            <div style="width:80px;height:80px;border-radius:50%;background:#eaffea;color:#21b65f;display:grid;place-items:center;font-size:40px;margin:0 auto 24px;">
                ✓
            </div>

            <span style="color:#ff3131;font-weight:800;font-size:13px;">REQUEST RECEIVED</span>

            <h2 style="margin:10px 0 14px;">Your reservation request has been submitted.</h2>

            <p style="color:#777;line-height:1.8;margin-bottom:30px;">
                Your driver license information and reservation request will be reviewed by the admin team.
                After approval, your rental confirmation will be completed.
            </p>

            <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
                <a href="/Car" class="btn-style-one">
                    Browse More Cars <i class="icon-13"></i>
                </a>

                <a href="/" class="btn-style-three">
                    Back to Home
                </a>
            </div>
        </div>
    </div>
</section>