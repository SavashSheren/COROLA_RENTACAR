@model List<COROLA_RENTACAR.EntityLayer.Entities.CarImage>

@{
    ViewData["Title"] = "Car Images";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    var totalCount = Model?.Count ?? 0;
    var coverCount = Model?.Count(x => x.IsCoverImage) ?? 0;
}

<style>
    .ci-root {
        padding: 28px;
        color: #e2e8f0;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    .ci-breadcrumb {
        font-size: 12px;
        color: #7a8499;
        margin-bottom: 8px;
    }

    .ci-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .ci-title {
        font-size: 26px;
        font-weight: 800;
        margin: 0;
        color: #e2e8f0;
    }

    .ci-subtitle {
        color: #7a8499;
        font-size: 13px;
        margin-top: 6px;
    }

    .btn-accent {
        background: #e8ff47;
        color: #0d0f14;
        border: none;
        border-radius: 10px;
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
    }

    .btn-edit {
        background: rgba(79,141,255,.12);
        color: #4f8dff;
        border: 1px solid rgba(79,141,255,.25);
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
    }

    .btn-danger {
        background: rgba(255,82,89,.1);
        color: #ff5259;
        border: 1px solid rgba(255,82,89,.2);
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
    }

    .ci-stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(180px, 280px));
        gap: 14px;
        margin-bottom: 20px;
    }

    .ci-stat {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 14px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .ci-stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: rgba(232,255,71,.12);
        color: #e8ff47;
        display: grid;
        place-items: center;
        font-size: 20px;
    }

        .ci-stat-icon.blue {
            background: rgba(79,141,255,.12);
            color: #4f8dff;
        }

    .ci-stat-num {
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .ci-stat-label {
        color: #7a8499;
        font-size: 12px;
        margin-top: 4px;
    }

    .ci-toolbar {
        display: flex;
        gap: 12px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .ci-search {
        min-width: 260px;
        max-width: 440px;
        flex: 1;
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 10px;
        color: #e2e8f0;
        padding: 11px 13px;
        outline: none;
    }

    .ci-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 18px;
    }

    .ci-card {
        background: #13161e;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 18px;
        overflow: hidden;
    }

    .ci-image {
        height: 190px;
        background: #1a1e2a;
        position: relative;
        overflow: hidden;
    }

        .ci-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .ci-cover-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(232,255,71,.16);
        color: #e8ff47;
        border: 1px solid rgba(232,255,71,.32);
        border-radius: 8px;
        padding: 5px 10px;
        font-size: 12px;
        font-weight: 800;
        backdrop-filter: blur(6px);
    }

    .ci-body {
        padding: 16px;
    }

    .ci-id {
        color: #7a8499;
        font-size: 12px;
        margin-bottom: 8px;
    }

    .ci-car-name {
        font-size: 18px;
        font-weight: 900;
        margin-bottom: 4px;
    }

    .ci-meta {
        color: #7a8499;
        font-size: 13px;
        margin-bottom: 14px;
    }

    .ci-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .ci-empty {
        grid-column: 1 / -1;
        text-align: center;
        color: #7a8499;
        padding: 60px 20px;
    }

    @@media(max-width: 700px) {
        .ci-stats {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="ci-root">

    <div class="ci-breadcrumb">
        Vehicle Management › Car Images
    </div>

    <div class="ci-header">
        <div>
            <h1 class="ci-title">Car Image Management</h1>
            <p class="ci-subtitle">Manage gallery images and cover images for rental cars.</p>
        </div>

        <a href="/Admin/CarImage/CreateCarImage" class="btn-accent">
            ＋ Add New Image
        </a>
    </div>

    <div class="ci-stats">
        <div class="ci-stat">
            <div class="ci-stat-icon">🖼️</div>
            <div>
                <div class="ci-stat-num">@totalCount</div>
                <div class="ci-stat-label">Total Images</div>
            </div>
        </div>

        <div class="ci-stat">
            <div class="ci-stat-icon blue">⭐</div>
            <div>
                <div class="ci-stat-num">@coverCount</div>
                <div class="ci-stat-label">Cover Images</div>
            </div>
        </div>
    </div>

    <div class="ci-toolbar">
        <input type="text" id="imageSearch" class="ci-search" placeholder="Search car, brand, model..." oninput="filterImages()" />
    </div>

    <div class="ci-grid" id="imageGrid">
        @if (Model == null || !Model.Any())
        {
            <div class="ci-empty">
                <div style="font-size:42px;">🖼️</div>
                <p>No car images found.</p>
            </div>
        }
        else
        {
            foreach (var image in Model)
            {
                var brandName = image.Car?.Brand?.BrandName ?? "";
                var modelName = image.Car?.Model ?? "";
                var categoryName = image.Car?.Category?.CategoryName ?? "";
                var plateNumber = image.Car?.PlateNumber ?? "";
                var searchText = $"{brandName} {modelName} {categoryName} {plateNumber}".ToLower();

                <div class="ci-card" data-search="@searchText">
                    <div class="ci-image">
                        <img src="@image.ImageUrl"
                             alt="@brandName @modelName"
                             onerror="this.style.display='none';" />

                        @if (image.IsCoverImage)
                        {
                            <span class="ci-cover-badge">⭐ Cover Image</span>
                        }
                    </div>

                    <div class="ci-body">
                        <div class="ci-id">#@image.CarImageId</div>
                        <div class="ci-car-name">@brandName @modelName</div>
                        <div class="ci-meta">@categoryName • @plateNumber</div>

                        <div class="ci-actions">
                            <a href="/Admin/CarImage/UpdateCarImage?id=@image.CarImageId" class="btn-edit">✏️ Edit</a>

                            @if (!image.IsCoverImage)
                            {
                                <form method="post" action="/Admin/CarImage/SetCoverImage?id=@image.CarImageId">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-edit">⭐ Set Cover</button>
                                </form>
                            }

                            <form method="post" action="/Admin/CarImage/DeleteCarImage?id=@image.CarImageId" onsubmit="return confirm('Are you sure you want to delete this image?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-danger">🗑️ Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
    function filterImages() {
        const q = document.getElementById('imageSearch').value.toLowerCase();
        const cards = document.querySelectorAll('.ci-card');

        cards.forEach(card => {
            const text = card.getAttribute('data-search') || '';
            card.style.display = text.includes(q) ? '' : 'none';
        });
    }
</script>
