@model List<COROLA_RENTACAR.EntityLayer.Entities.Car>

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_UILayout.cshtml";

    var latestCars = Model == null
        ? new List<COROLA_RENTACAR.EntityLayer.Entities.Car>()
        : Model.Take(3).ToList();

    var featuredCars = Model == null
        ? new List<COROLA_RENTACAR.EntityLayer.Entities.Car>()
        : Model.Take(6).ToList();
}

<style>
    .home-page {
        background: #f6f7fb;
    }

    .hero-slider-section {
        padding: 50px 0 30px;
        background: linear-gradient(135deg, #111827, #1f2937);
    }

    .slider-box {
        position: relative;
        border-radius: 30px;
        overflow: hidden;
        min-height: 500px;
        background: #111827;
        box-shadow: 0 28px 80px rgba(0, 0, 0, .28);
    }

    .slider-item {
        display: none;
        min-height: 500px;
        position: relative;
        color: #fff;
    }

        .slider-item.active {
            display: block;
        }

    .slider-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

        .slider-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .slider-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(17,24,39,.94), rgba(17,24,39,.72), rgba(17,24,39,.18));
    }

    .slider-content {
        position: relative;
        z-index: 2;
        max-width: 620px;
        padding: 70px 54px;
    }

    .slider-badge {
        display: inline-block;
        background: rgba(255,255,255,.13);
        border: 1px solid rgba(255,255,255,.18);
        color: #e5e7eb;
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 800;
        margin-bottom: 20px;
    }

    .slider-content h1 {
        font-size: 54px;
        line-height: 1.06;
        font-weight: 950;
        letter-spacing: -1.4px;
        margin-bottom: 18px;
    }

    .slider-content p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.8;
        margin-bottom: 28px;
    }

    .slider-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-white-home {
        display: inline-block;
        background: #fff;
        color: #111827;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 900;
        text-decoration: none;
    }

    .btn-dark-outline-home {
        display: inline-block;
        border: 1px solid rgba(255,255,255,.28);
        color: #fff;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 900;
        text-decoration: none;
    }

    .slider-nav {
        position: absolute;
        right: 28px;
        bottom: 28px;
        z-index: 5;
        display: flex;
        gap: 10px;
    }

        .slider-nav button {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            border: none;
            background: rgba(255,255,255,.92);
            color: #111827;
            font-weight: 950;
            cursor: pointer;
        }

    .quick-info-section {
        margin-top: -40px;
        position: relative;
        z-index: 10;
    }

    .quick-card {
        background: #fff;
        border-radius: 24px;
        padding: 28px;
        height: 100%;
        box-shadow: 0 18px 50px rgba(15,23,42,.11);
    }

    .quick-card-icon {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        background: #111827;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 950;
        margin-bottom: 18px;
    }

    .quick-card h4 {
        font-weight: 950;
        color: #111827;
        margin-bottom: 10px;
    }

    .quick-card p {
        color: #6b7280;
        line-height: 1.7;
        margin-bottom: 18px;
    }

    .quick-card a {
        color: #111827;
        font-weight: 900;
        text-decoration: none;
    }

    .section-padding {
        padding: 80px 0;
    }

    .section-title {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 20px;
        margin-bottom: 34px;
    }

        .section-title span {
            display: block;
            color: #6b7280;
            font-size: 13px;
            font-weight: 900;
            letter-spacing: .09em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .section-title h2 {
            color: #111827;
            font-size: 38px;
            font-weight: 950;
            margin-bottom: 0;
        }

        .section-title p {
            color: #6b7280;
            margin-bottom: 0;
            max-width: 520px;
        }

    .car-card {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        height: 100%;
        box-shadow: 0 18px 50px rgba(15,23,42,.08);
        transition: .2s;
    }

        .car-card:hover {
            transform: translateY(-5px);
        }

    .car-image {
        height: 230px;
        position: relative;
        background: #e5e7eb;
    }

        .car-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .price-badge {
        position: absolute;
        left: 16px;
        top: 16px;
        background: #111827;
        color: #fff;
        padding: 9px 14px;
        border-radius: 999px;
        font-weight: 900;
        font-size: 13px;
    }

    .available-badge {
        position: absolute;
        right: 16px;
        top: 16px;
        background: #dcfce7;
        color: #166534;
        padding: 9px 14px;
        border-radius: 999px;
        font-weight: 900;
        font-size: 13px;
    }

    .car-body {
        padding: 24px;
    }

        .car-body h4 {
            color: #111827;
            font-weight: 950;
            margin-bottom: 8px;
        }

        .car-body p {
            color: #6b7280;
            margin-bottom: 18px;
        }

    .spec-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 20px;
    }

    .spec-box {
        background: #f9fafb;
        border-radius: 14px;
        padding: 12px;
        text-align: center;
    }

        .spec-box small {
            display: block;
            color: #6b7280;
            font-weight: 700;
            margin-bottom: 3px;
        }

        .spec-box strong {
            color: #111827;
            font-weight: 900;
        }

    .rules-section {
        background: #111827;
        color: #fff;
        padding: 80px 0;
    }

    .rule-box {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 24px;
        padding: 28px;
        height: 100%;
    }

        .rule-box strong {
            display: inline-flex;
            width: 44px;
            height: 44px;
            border-radius: 15px;
            background: #fff;
            color: #111827;
            align-items: center;
            justify-content: center;
            font-weight: 950;
            margin-bottom: 18px;
        }

        .rule-box h4 {
            font-weight: 950;
            margin-bottom: 10px;
        }

        .rule-box p {
            color: #cbd5e1;
            margin-bottom: 0;
            line-height: 1.7;
        }

    .cta-section {
        padding: 80px 0;
        background: #f6f7fb;
    }

    .cta-box {
        background: #111827;
        color: #fff;
        border-radius: 28px;
        padding: 48px;
    }

        .cta-box h2 {
            font-weight: 950;
            font-size: 38px;
            margin-bottom: 12px;
        }

        .cta-box p {
            color: #cbd5e1;
            margin-bottom: 0;
            line-height: 1.8;
        }

    @@media(max-width: 768px) {
        .slider-content {
            padding: 44px 28px;
        }

            .slider-content h1 {
                font-size: 36px;
            }

        .section-title {
            display: block;
        }

            .section-title h2 {
                font-size: 30px;
            }

        .spec-grid {
            grid-template-columns: 1fr;
        }

        .cta-box {
            padding: 30px;
        }
    }
</style>

<div class="home-page">

    <section class="hero-slider-section">
        <div class="container">

            @if (latestCars.Any())
            {
                <div class="slider-box" id="latestCarSlider">
                    @for (int i = 0; i < latestCars.Count; i++)
                    {
                        var car = latestCars[i];
                        var imageUrl = string.IsNullOrWhiteSpace(car.ImageUrl)
                        ? "/images/default-car.jpg"
                        : car.ImageUrl;

                        <div class="slider-item @(i == 0 ? "active" : "")">
                            <div class="slider-image">
                                <img src="@imageUrl" alt="@car.Brand?.BrandName @car.Model" />
                            </div>

                            <div class="slider-overlay"></div>

                            <div class="slider-content">
                                <div class="slider-badge">
                                    Newly Added Rental Car
                                </div>

                                <h1>@car.Brand?.BrandName @car.Model</h1>

                                <p>
                                    @car.ModelYear model, @car.FuelType fuel, @car.TransmissionType transmission.
                                    Available for daily and short-term rental requests.
                                </p>

                                <div class="slider-actions">
                                    <a asp-controller="Reservation"
                                       asp-action="Create"
                                       asp-route-carId="@car.CarId"
                                       class="btn-white-home">
                                        Rent This Car
                                    </a>

                                    <a asp-controller="Car"
                                       asp-action="Detail"
                                       asp-route-id="@car.CarId"
                                       class="btn-dark-outline-home">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="slider-nav">
                        <button type="button" onclick="changeSlide(-1)">‹</button>
                        <button type="button" onclick="changeSlide(1)">›</button>
                    </div>
                </div>
            }
            else
            {
                <div class="slider-box">
                    <div class="slider-item active">
                        <div class="slider-overlay"></div>

                        <div class="slider-content">
                            <div class="slider-badge">COROLA Rent A Car</div>
                            <h1>Find The Right Car For Your Trip</h1>
                            <p>
                                Available vehicles will appear here once they are added from the admin panel.
                            </p>

                            <div class="slider-actions">
                                <a asp-controller="Car" asp-action="Index" class="btn-white-home">
                                    Browse Cars
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    </section>

    <section class="quick-info-section">
        <div class="container">
            <div class="row g-4">

                <div class="col-lg-4">
                    <div class="quick-card">
                        <div class="quick-card-icon">01</div>
                        <h4>Newly Added Cars</h4>
                        <p>
                            Check the latest vehicles added to the fleet and choose the right option for your trip.
                        </p>
                        <a asp-controller="Car" asp-action="Index">Browse fleet →</a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="quick-card">
                        <div class="quick-card-icon">02</div>
                        <h4>Rental Rules</h4>
                        <p>
                            Select pickup and return dates carefully. Reservation requests are reviewed before approval.
                        </p>
                        <a asp-controller="Home" asp-action="About">Learn more →</a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="quick-card">
                        <div class="quick-card-icon">03</div>
                        <h4>Track Reservation</h4>
                        <p>
                            Already created a request? Use your reservation code and email to check the latest status.
                        </p>
                        <a asp-controller="Reservation" asp-action="Track">Track now →</a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="section-padding">
        <div class="container">

            <div class="section-title">
                <div>
                    <span>Available Fleet</span>
                    <h2>Choose Your Rental Car</h2>
                </div>

                <p>
                    Compare available vehicles by price, fuel type, transmission, passenger capacity and luggage capacity.
                </p>
            </div>

            @if (!featuredCars.Any())
            {
                <div class="bg-white text-center p-5 shadow-sm" style="border-radius:24px;">
                    <h4 style="font-weight:900;">No available cars yet.</h4>
                    <p class="text-muted mb-0">Available cars will be listed here soon.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var car in featuredCars)
                    {
                        var imageUrl = string.IsNullOrWhiteSpace(car.ImageUrl)
                        ? "/images/default-car.jpg"
                        : car.ImageUrl;

                        <div class="col-lg-4 col-md-6">
                            <div class="car-card">
                                <div class="car-image">
                                    <img src="@imageUrl" alt="@car.Brand?.BrandName @car.Model" />

                                    <span class="price-badge">
                                        @car.DailyPrice.ToString("N0") ₺ / Day
                                    </span>

                                    <span class="available-badge">
                                        Available
                                    </span>
                                </div>

                                <div class="car-body">
                                    <h4>@car.Brand?.BrandName @car.Model</h4>

                                    <p>
                                        @car.ModelYear model · @car.FuelType · @car.TransmissionType
                                    </p>

                                    <div class="spec-grid">
                                        <div class="spec-box">
                                            <small>Seats</small>
                                            <strong>@car.SeatCount</strong>
                                        </div>

                                        <div class="spec-box">
                                            <small>Luggage</small>
                                            <strong>@car.LuggageCapacity</strong>
                                        </div>

                                        <div class="spec-box">
                                            <small>Category</small>
                                            <strong>@car.Category?.CategoryName</strong>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <a asp-controller="Car"
                                           asp-action="Detail"
                                           asp-route-id="@car.CarId"
                                           class="btn btn-outline-dark w-100">
                                            Details
                                        </a>

                                        <a asp-controller="Reservation"
                                           asp-action="Create"
                                           asp-route-carId="@car.CarId"
                                           class="btn btn-dark w-100">
                                            Rent Now
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-5">
                    <a asp-controller="Car"
                       asp-action="Index"
                       class="btn btn-dark px-5 py-3"
                       style="border-radius:14px;font-weight:900;">
                        View All Cars
                    </a>
                </div>
            }

        </div>
    </section>

    <section class="rules-section">
        <div class="container">
            <div class="section-title">
                <div>
                    <span style="color:#cbd5e1;">Before Renting</span>
                    <h2 style="color:white;">Quick Rental Information</h2>
                </div>

                <p style="color:#cbd5e1;">
                    A clear rental process helps you choose the right car and avoid confusion before creating a request.
                </p>
            </div>

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="rule-box">
                        <strong>1</strong>
                        <h4>Choose Dates Correctly</h4>
                        <p>
                            Pickup and return dates are important for availability checks and total rental price calculation.
                        </p>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="rule-box">
                        <strong>2</strong>
                        <h4>Wait For Approval</h4>
                        <p>
                            Reservation requests are reviewed before confirmation. You will receive approval information after review.
                        </p>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="rule-box">
                        <strong>3</strong>
                        <h4>Use Your Code</h4>
                        <p>
                            Your reservation code helps you track your request status anytime from the tracking page.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container">
            <div class="cta-box">
                <div class="row align-items-center g-4">
                    <div class="col-lg-8">
                        <h2>Ready To Choose Your Car?</h2>
                        <p>
                            Browse the fleet, compare vehicles and create your rental request with a clear step-by-step process.
                        </p>
                    </div>

                    <div class="col-lg-4 text-lg-end">
                        <a asp-controller="Car" asp-action="Index" class="btn-white-home">
                            Browse Cars
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

<script>
    let currentSlide = 0;

    function showSlide(index) {
        const slides = document.querySelectorAll("#latestCarSlider .slider-item");

        if (!slides || slides.length === 0) {
            return;
        }

        if (index >= slides.length) {
            currentSlide = 0;
        } else if (index < 0) {
            currentSlide = slides.length - 1;
        } else {
            currentSlide = index;
        }

        slides.forEach(slide => slide.classList.remove("active"));
        slides[currentSlide].classList.add("active");
    }

    function changeSlide(direction) {
        showSlide(currentSlide + direction);
    }

    setInterval(function () {
        changeSlide(1);
    }, 6000);
</script>